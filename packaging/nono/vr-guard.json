{
  "extends": "swival",
  "meta": {
    "name": "vr-guard",
    "description": "Visual Relay guard: broad read + network + tools open; writes and deletes confined to the granted workspace. Accident containment, not adversarial isolation."
  },
  "filesystem": {
    "read": ["/", "$HOME/.gitconfig"],
    "allow": [
      "$TMPDIR",
      "$HOME/.config/swival",
      "$HOME/.local/share/swival",
      "$HOME/.nuget/packages",
      "$HOME/.dotnet",
      "$HOME/.templateengine",
      { "path": "$HOME/Library/Caches/NuGet", "when": "macos" },
      { "path": "$XDG_CACHE_HOME/NuGet", "when": "linux" },
      "$HOME/.local/share/NuGet",
      { "path": "$HOME/.local/share/uv", "when": "linux" },
      "$HOME/.swiftpm",
      { "path": "$HOME/Library/Caches/org.swift.swiftpm", "when": "macos" },
      { "path": "$HOME/Library/org.swift.swiftpm", "when": "macos" },
      { "path": "$HOME/.cache/org.swift.swiftpm", "when": "linux" },
      { "path": "$XDG_CACHE_HOME/org.swift.swiftpm", "when": "linux" },
      "$HOME/.npm",
      "$HOME/.bun",
      "$HOME/.deno",
      "$HOME/.pnpm-store",
      "$HOME/.yarn",
      "$HOME/.cloakbrowser",
      { "path": "$HOME/Library/Caches/node-gyp", "when": "macos" },
      "$HOME/.pyenv",
      { "path": "$HOME/Library/Caches/pip", "when": "macos" },
      { "path": "$HOME/Library/Caches/uv", "when": "macos" },
      { "path": "$HOME/.cache/pip", "when": "linux" },
      { "path": "$HOME/.cache/uv", "when": "linux" },
      { "path": "$XDG_CACHE_HOME/pip", "when": "linux" },
      { "path": "$XDG_CACHE_HOME/uv", "when": "linux" },
      "$HOME/go/pkg/mod",
      { "path": "$HOME/Library/Caches/go-build", "when": "macos" },
      { "path": "$HOME/.cache/go-build", "when": "linux" },
      { "path": "$XDG_CACHE_HOME/go-build", "when": "linux" },
      "$HOME/.cargo",
      "$HOME/.cache/nix",
      "$HOME/.local/state/nix"
    ],
    "write": [
    ],
    "deny": [
      "$HOME/Documents",
      "$HOME/Desktop",
      "$HOME/Pictures",
      "$HOME/Movies",
      "$HOME/Music"
    ]
  },
  "rollback": {
    "exclude_patterns": [
      "node_modules",
      "__pycache__",
      ".swival",
      ".nuget",
      "NuGet",
      ".dotnet",
      ".templateengine",
      ".swiftpm",
      "org.swift.swiftpm",
      ".npm",
      ".bun",
      ".deno",
      ".pnpm-store",
      ".yarn",
      "node-gyp",
      ".pyenv",
      ".cargo",
      ".cache",
      "Caches",
      "/go/pkg/",
      "/.config/swival",
      "/.local/share/swival",
      "/.local/state/nix"
    ],
    "exclude_globs": [
      "*.pyc"
    ]
  },
  "groups": {
    "include": [
      "go_runtime",
      "rust_runtime"
    ]
  },
  "allow_parent_of_protected": true,
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)",
    "(allow ipc-posix-shm*)",
    "(allow mach-register)",
    "(allow sysctl-read)",
    "(allow iokit-open)",
    "(allow iokit-get-properties)",
    "(allow system-socket)"
  ]
}
