{
  "testCmd": "dotnet test tests/VisualRelay.Tests/VisualRelay.Tests.csproj -m:1 -p:UseSharedCompilation=false",
  "testFileCmd": "dotnet test tests/VisualRelay.Tests/VisualRelay.Tests.csproj -m:1 -p:UseSharedCompilation=false",
  "logSources": [],
  "tierProfiles": {
    "cheap": "cheap",
    "balanced": "balanced",
    "frontier": "frontier",
    "vision": "vision"
  },
  "baselineVerify": true,
  "bypassSandbox": false,
  "archiveOnDone": true,
  "maxTurns": 200,
  "subagentTimeoutMs": 0,
  "testTimeoutMs": 600000,
  "firstOutputTimeoutMsByTier": {
    "cheap": 120000,
    "balanced": 120000,
    "frontier": 660000
  },
  "inactivityTimeoutMsByTier": {
    "cheap": 600000,
    "balanced": 600000,
    "frontier": 1200000
  },
  "maxStallRetries": 2,
  "guardCmd": "tools/guards/guard-source-enumeration.sh && tools/guards/check-file-size.sh && dotnet format VisualRelay.slnx --verify-no-changes"
}
