{
  "testCmd": "dotnet test tests/VisualRelay.Tests/VisualRelay.Tests.csproj -m:1 -p:UseSharedCompilation=false",
  "testFileCmd": "sh tools/dotnet-test-files.sh {files}",
  "logSources": [],
  "tierProfiles": {
    "cheap": "cheap",
    "balanced": "balanced",
    "frontier": "frontier",
    "vision": "vision"
  },
  "baselineVerify": false,
  "archiveOnDone": true,
  "maxTurns": 200,
  "subagentTimeoutMs": 1800000,
  "testTimeoutMs": 600000,
  "firstOutputTimeoutMsByTier": {
    "cheap": 120000,
    "balanced": 120000,
    "frontier": 660000
  },
  "inactivityTimeoutMsByTier": {
    "cheap": 600000,
    "balanced": 600000,
    "frontier": 1200000
  },
  "maxStallRetries": 2,
  "guardCmd": "dotnet run --project tools/VisualRelay.Guards -- source-enumeration && dotnet run --project tools/VisualRelay.Guards -- file-size && dotnet format VisualRelay.slnx --verify-no-changes",
  "formatCmd": "dotnet format VisualRelay.slnx"
}
