#!/usr/bin/env bash
# Visual Relay commit-msg hook — thin wrapper.
#
# All rule logic lives in C# (VisualRelay.Core/CommitLint, exercised by
# tools/VisualRelay.CheckCommitMessage). This wrapper only locates and execs the
# validator, passing the commit-message file. It prefers a prebuilt published
# binary so the hook NEVER triggers a build at commit time — important under the
# nono sandbox during a Visual Relay run. It falls back to `dotnet run` only when
# no published binary exists (developer machine without a publish).
set -euo pipefail

# Resolve this hook's real directory, following symlinks, then the repo root
# (the .githooks dir's parent).
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$dir/$SOURCE"
done
HOOK_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
SCRIPT_DIR="$(cd -P "$HOOK_DIR/.." && pwd)"

message_file="$1"

# Published (self-contained) binary fast path — mirrors PUBLISHED_INIT in the
# `visual-relay` launcher. `./visual-relay install-hooks` publishes the tool here.
PUBLISHED="$SCRIPT_DIR/check-commit-message/VisualRelay.CheckCommitMessage"
if [[ -x "$PUBLISHED" ]]; then
  exec "$PUBLISHED" "$message_file"
fi

# Fallback: dotnet run (no build forced beyond what `dotnet run` does on a dev
# machine). Never reached during a sandboxed run because install-hooks publishes.
if command -v dotnet >/dev/null 2>&1; then
  exec dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.CheckCommitMessage" -- "$message_file"
fi

echo "commit-msg: neither a published validator nor dotnet found." >&2
echo "Run ./visual-relay install-hooks to publish the validator." >&2
exit 2
