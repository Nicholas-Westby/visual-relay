#!/usr/bin/env bash
# Visual Relay command-guard hook — thin wrapper.
# Swival --command-middleware target that strips git hook-bypass flags.
# All logic lives in C# (VisualRelay.Core/CommandGuard).
# Prefers the prebuilt published binary; falls back to dotnet run.
set -euo pipefail

# Resolve this script's real directory, following symlinks.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$dir/$SOURCE"
done
HOOK_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
SCRIPT_DIR="$(cd -P "$HOOK_DIR/.." && pwd)"

# Published binary fast path.
PUBLISHED="$SCRIPT_DIR/command-guard/VisualRelay.CommandGuard"
if [[ -x "$PUBLISHED" ]]; then
  exec "$PUBLISHED"
fi

# Fallback: dotnet run.
if command -v dotnet >/dev/null 2>&1; then
  exec dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.CommandGuard" --
fi

# Fail-open: emit allow so the agent isn't blocked.
printf '{"action":"allow"}\n'
