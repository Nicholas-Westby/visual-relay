root = true

[*.cs]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_prefer_collection_expression = true:suggestion
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion

# ── Durable carve-outs (false positives on this stack) ────────────────────

# CommunityToolkit [ObservableProperty] backing-field initializers are wrongly
# flagged "ignored" — the generator reads and forwards the value.
resharper_member_initializer_value_ignored_highlighting = none

# Avalonia codegen supplies the 2nd partial half of *.axaml.cs classes at build
# (×5 repo-wide). InspectCode sees only the hand-written half and fires
# PartialTypeWithSinglePart.
resharper_partial_type_with_single_part_highlighting = none

# Entry-point / runtime-instantiated types (Program, ViewLocator,
# GuiTaskRunner, etc.) are constructed by the framework/Avalonia DI, not by
# visible C# instantiation.
resharper_class_never_instantiated_global_highlighting = none

# Interface-contract params (e.g. CancellationToken) unused in some
# implementations (×3 repo-wide). Carried for interface compliance.
resharper_unused_parameter_global_highlighting = none

# ── Opinion-style decisions (per-family comply-or-silence) ─────────────────
# Each is a deliberate team choice.  Rules not listed here remain at their
# default (mostly warning) and must be kept clean.

# The async-over-sync naming convention (e.g. every sync method also having an
# Async overload) is noise for this codebase — methods are either inherently
# sync or async; the overload pattern is not useful here.
resharper_method_has_async_overload_highlighting = none

# Explicit property accessors are preferred over field-keyword shorthand for
# clarity and grep-ability across the codebase.
resharper_replace_with_field_keyword_highlighting = none

# Nullable suppression expressions are often required by the interaction of
# CommunityToolkit generators and Avalonia binding — removing them breaks
# builds.  Deliberately keep them explicit.
resharper_redundant_suppress_nullable_warning_expression_highlighting = none

# Lock-object field types (object vs Lock) — the System.Threading.Lock type
# offers no practical benefit in our single-process GUI context.
resharper_change_field_type_to_system_threading_lock_highlighting = none

# ── Project-specific diagnostics ──────────────────────────────────────────

# xUnit1051 wants TestContext.Current.CancellationToken at every xUnit API call site.
# Suppressed deliberately: this is a fast unit suite and many call sites pass
# CancellationToken.None on purpose; threading TestContext through ~250 sites is scope
# creep orthogonal to the xunit v3 / [AvaloniaFact] migration and risks mistakes.
# Revisit later if cancellation responsiveness ever matters here.
dotnet_diagnostic.xUnit1051.severity = none

# RS0030 (BannedApiAnalyzers): make banned-symbol use a hard error. Bans
# Avalonia.Headless.HeadlessUnitTestSession (see tests/VisualRelay.Tests/BannedSymbols.txt)
# — hand-rolled headless sessions deadlock the suite; use [AvaloniaFact] instead.
dotnet_diagnostic.RS0030.severity = error

[*.{axaml,csproj,slnx,xml}]
indent_style = space
indent_size = 2

# Avalonia Grid auto-layout handles missing Grid.Row/Column just fine; adding
# explicit indices to every child is ceremony without value. This inspection
# only fires on XAML, so it is scoped to the axaml section.
resharper_xaml_missing_grid_index_highlighting = none

[*.{md,sh,nix}]
end_of_line = lf
insert_final_newline = true
