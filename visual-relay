#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-launch}"
shift || true
export AVALONIA_TELEMETRY_OPTOUT=1
export DOTNET_CLI_TELEMETRY_OPTOUT=1
export MSBUILDDISABLENODEREUSE=1

needs_dotnet=0
case "$cmd" in
  launch|run|build|test|format|screenshot|sample-reset|run-task|init|check|gen-backend-config)
    needs_dotnet=1
    ;;
esac

if (( needs_dotnet )) && ! command -v dotnet >/dev/null 2>&1; then
  nix_bin=""
  if command -v nix >/dev/null 2>&1; then
    nix_bin="$(command -v nix)"
  elif [[ -x /nix/var/nix/profiles/default/bin/nix ]]; then
    nix_bin="/nix/var/nix/profiles/default/bin/nix"
  elif [[ -x /run/current-system/sw/bin/nix ]]; then
    nix_bin="/run/current-system/sw/bin/nix"
  fi

  if [[ -n "$nix_bin" ]]; then
    echo "visual-relay: dotnet not found; entering nix develop for this command" >&2
    exec env -u DOTNET_ROOT "$nix_bin" develop --command bash "$0" "$cmd" "$@"
  fi

  echo "visual-relay: dotnet not found. Install .NET 10 or run: nix develop" >&2
  exit 127
fi

# ---------- watchdog ----------
_timeout_watchdog() {
  local timeout_secs="${VISUAL_RELAY_TEST_TIMEOUT:-60}"
  local cmd_pid watchdog_pid cmd_rc
  local flag_file
  flag_file="$(mktemp 2>/dev/null || echo "/tmp/.visual-relay-watchdog-$$")"

  # Launch the real command in its own process group so we can kill the whole
  # tree (dotnet → testhost → tests) on timeout.
  set -m
  "$@" &
  cmd_pid=$!

  # Background timer: when it expires, check whether the command is still alive
  # and kill the process group if so.  Writes a flag file so the main function
  # always exits non-zero on timeout even when the killed process handles
  # SIGTERM by exiting 0 (dotnet does this).
  (
    sleep "$timeout_secs"
    if kill -0 "$cmd_pid" 2>/dev/null; then
      echo "timed out" > "$flag_file"
      echo "visual-relay: test timed out after ${timeout_secs}s" >&2
      echo "  See TROUBLESHOOTING.md for diagnosing hangs." >&2
      echo "  To find which test is stuck: ./visual-relay test --blame-hang --blame-hang-timeout 30s" >&2
      echo "  Override timeout: VISUAL_RELAY_TEST_TIMEOUT=<seconds> ./visual-relay test" >&2
      kill -TERM -- -"$cmd_pid" 2>/dev/null || true
      sleep 1
      kill -KILL -- -"$cmd_pid" 2>/dev/null || true
    fi
  ) &
  watchdog_pid=$!

  # Wait for the command (not the watchdog).
  cmd_rc=0
  wait "$cmd_pid" 2>/dev/null || cmd_rc=$?

  # Tear down the watchdog timer AND its 'sleep' child. Under 'set -m' the timer
  # subshell is its own process-group leader, so kill the whole group (negative
  # PID). A bare 'kill "$watchdog_pid"' only signals the subshell leader and can
  # lose a race in which the subshell has already forked 'sleep': that 'sleep' is
  # then orphaned and, because it inherited this function's stdout/stderr, keeps
  # the pipe open until the timeout elapses. Any caller capturing output (CI,
  # $(...), the relay's ProcessCapture) would block for the full timeout even
  # though the command already finished.
  # Kill direct children first (pkill -P) so 'sleep' is reaped even when
  # set -m didn't establish a process group (non-interactive shells); then
  # kill the process group (or just the process as a fallback).
  pkill -P "$watchdog_pid" 2>/dev/null || true
  kill -- -"$watchdog_pid" 2>/dev/null || kill "$watchdog_pid" 2>/dev/null || true
  wait "$watchdog_pid" 2>/dev/null || true

  # If the watchdog fired, override the exit code.  Some programs (dotnet)
  # catch SIGTERM and exit 0, which would hide the timeout.
  if [[ -s "$flag_file" ]]; then
    cmd_rc=124   # GNU timeout convention
  fi
  rm -f "$flag_file"

  return "$cmd_rc"
}

case "$cmd" in
  launch|run)
    # Best-effort: bring the local model backend up before launching so a fresh
    # launch can run a task without a manual proxy step. Idempotent and fast
    # when already healthy; if it fails (e.g. litellm not installed) the launch
    # still proceeds and the in-app pre-flight probe surfaces the down backend.
    tools/backend/backend.sh start || \
      echo "visual-relay: backend start failed; launching anyway (in-app probe will flag a down backend)" >&2
    dotnet run --project src/VisualRelay.App/VisualRelay.App.csproj -- "$@"
    ;;
  build)
    tools/guards/guard-source-enumeration.sh
    dotnet build VisualRelay.slnx -m:1 -p:UseSharedCompilation=false "$@"
    ;;
  test)
    _timeout_watchdog dotnet test tests/VisualRelay.Tests/VisualRelay.Tests.csproj -m:1 -p:UseSharedCompilation=false "$@"
    ;;
  format)
    dotnet format VisualRelay.slnx "$@"
    ;;
  screenshot)
    dotnet run --project tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj -- docs/images/visual-relay-main.png
    dotnet run --project tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj -- docs/images/visual-relay-compact.png 1060 720
    ;;
  sample-reset)
    dotnet run --project tools/VisualRelay.SampleTasks/VisualRelay.SampleTasks.csproj -- "${1:-../sample-tasks}"
    ;;
  run-task)
    dotnet run --project tools/VisualRelay.RunTask/VisualRelay.RunTask.csproj -- "$@"
    ;;
  init)
    dotnet run --project tools/VisualRelay.Init/VisualRelay.Init.csproj -- "$@"
    ;;
  install-hooks)
    git config core.hooksPath .githooks
    chmod +x .githooks/commit-msg .githooks/pre-commit tools/guards/check-file-size.sh visual-relay
    ;;
  check)
    tools/guards/guard-source-enumeration.sh
    tools/guards/check-file-size.sh
    dotnet format VisualRelay.slnx --verify-no-changes
    dotnet build VisualRelay.slnx -m:1 -p:UseSharedCompilation=false
    dotnet test tests/VisualRelay.Tests/VisualRelay.Tests.csproj -m:1 -p:UseSharedCompilation=false
    dotnet build tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj -m:1 -p:UseSharedCompilation=false
    dotnet run --no-build --project tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj -- docs/images/visual-relay-main.png
    dotnet run --no-build --project tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj -- docs/images/visual-relay-compact.png 1060 720
    ;;
  gen-backend-config)
    dotnet run --project tools/VisualRelay.GenBackendConfig/VisualRelay.GenBackendConfig.csproj -- "$@"
    ;;
  *)
    echo "usage: ./visual-relay [launch|build|test|format|screenshot|sample-reset|run-task|init|install-hooks|check|gen-backend-config]" >&2
    exit 2
    ;;
esac
