#!/usr/bin/env bash
set -euo pipefail
main() {
# Resolve this script's real directory (follow symlinks for brew installs).
SCRIPT_DIR="$(
  target="${BASH_SOURCE[0]}"
  while [[ -L "$target" ]]; do
    target="$(readlink "$target")"
    [[ "$target" != /* ]] && target="$(dirname "${BASH_SOURCE[0]}")/$target"
  done
  cd "$(dirname "$target")" && pwd
)"
ORIGINAL_CWD="${ORIGINAL_CWD:-$PWD}"

cmd="${1:-launch}"
shift || true
ARGS=("$@")
export AVALONIA_TELEMETRY_OPTOUT=1
export DOTNET_CLI_TELEMETRY_OPTOUT=1
export MSBUILDDISABLENODEREUSE=1

# Published (self-contained) binary paths — present only in brew installs.
PUBLISHED_APP="$SCRIPT_DIR/app/VisualRelay.App"
PUBLISHED_INIT="$SCRIPT_DIR/init/VisualRelay.Init"
PUBLISHED_GC="$SCRIPT_DIR/gen-backend-config/VisualRelay.GenBackendConfig"
HAS_PUBLISHED=0
[[ -x "$PUBLISHED_APP" ]] && HAS_PUBLISHED=1

# ---------- nix location helper ----------
_find_nix() {
  if [[ -n "${_VISUAL_RELAY_FAKE_NO_NIX:-}" ]]; then
    return 0   # emit nothing; callers check for empty output
  fi
  if command -v nix >/dev/null 2>&1; then
    command -v nix
  elif [[ -x /nix/var/nix/profiles/default/bin/nix ]]; then
    echo "/nix/var/nix/profiles/default/bin/nix"
  elif [[ -x /run/current-system/sw/bin/nix ]]; then
    echo "/run/current-system/sw/bin/nix"
  fi
}

# ---------- always-enter nix devshell (when available) ----------
_ensure_devshell() {
  # Loop guard: only re-enter once.
  if [[ -n "${VISUAL_RELAY_NIX_REENTRY:-}" ]]; then
    return 0
  fi

  # Published self-contained installs ship their own runtime; don't force nix.
  if (( HAS_PUBLISHED )); then
    return 0
  fi

  local nix_bin; nix_bin="$(_find_nix)"
  if [[ -z "$nix_bin" ]]; then
    return 0  # No nix — fall through to per-tool checks and install offer.
  fi

  echo "visual-relay: entering nix develop for this command" >&2
  exec env -u DOTNET_ROOT VISUAL_RELAY_NIX_REENTRY=1 ORIGINAL_CWD="$ORIGINAL_CWD" \
    "$nix_bin" develop --command bash "$0" "$cmd" ${ARGS:+"${ARGS[@]}"}
}

# ---------- consent-gated Determinate Nix install offer ----------
_offer_nix_install() {
  local nix_bin; nix_bin="$(_find_nix)"
  if [[ -n "$nix_bin" ]]; then
    return 0
  fi

  # Already offered and declined in this invocation — don't re-ask.
  if [[ -n "${_VISUAL_RELAY_NIX_OFFERED:-}" ]]; then
    return 1
  fi
  _VISUAL_RELAY_NIX_OFFERED=1

  if [[ ! -t 0 || ! -t 1 ]]; then
    printf 'visual-relay: install Determinate Nix to provide the missing tools:\n  curl -fsSL https://install.determinate.systems/nix | sh -s -- install\n' >&2
    return 1
  fi

  printf 'visual-relay: required tools missing. Install Determinate Nix to provide them? [y/N] ' >&2
  IFS= read -r answer
  case "$answer" in
    [yY]|[yY][eE][sS])
      eval "${VISUAL_RELAY_NIX_INSTALLER:-curl -fsSL https://install.determinate.systems/nix | sh -s -- install}"
      unset _VISUAL_RELAY_FAKE_NO_NIX
      nix_bin="$(_find_nix)"
      if [[ -z "$nix_bin" ]]; then
        echo "visual-relay: Nix installed but not found at expected paths" >&2
        exit 1
      fi
      exec env -u DOTNET_ROOT VISUAL_RELAY_NIX_REENTRY=1 ORIGINAL_CWD="$ORIGINAL_CWD" "$nix_bin" develop --command bash "$0" "$cmd" ${ARGS:+"${ARGS[@]}"}
      ;;
    *)
      printf 'visual-relay: install Determinate Nix manually:\n  curl -fsSL https://install.determinate.systems/nix | sh -s -- install\n' >&2
      return 1
      ;;
  esac
}

# ---------- dotnet bootstrap (used by dotnet-only dispatch cases) ----------
_require_dotnet() {
  if command -v dotnet >/dev/null 2>&1; then
    return 0
  fi

  # If the unified gate already attempted nix re-entry, don't try again.
  if [[ -n "${VISUAL_RELAY_NIX_REENTRY:-}" ]]; then
    echo "visual-relay: dotnet not found. Install .NET 10 or run: nix develop" >&2
    exit 127
  fi

  local nix_bin; nix_bin="$(_find_nix)"
  if [[ -n "$nix_bin" ]]; then
    echo "visual-relay: dotnet not found; entering nix develop for this command" >&2
    exec env -u DOTNET_ROOT VISUAL_RELAY_NIX_REENTRY=1 ORIGINAL_CWD="$ORIGINAL_CWD" "$nix_bin" develop --command bash "$0" "$cmd" ${ARGS:+"${ARGS[@]}"}
  fi

  # No nix — offer to install it (on decline returns 1, fall through to exit).
  _offer_nix_install || true

  echo "visual-relay: dotnet not found. Install .NET 10 or run: nix develop" >&2
  exit 127
}

# ---------- unified prerequisite gate ----------
# Checks all required tools for the current command.  If any tool is missing
# and nix is available, re-execs once into `nix develop` with
# VISUAL_RELAY_NIX_REENTRY=1 so every subsequent call is a no-op.
# Hard tools (block launch): dotnet (unless HAS_PUBLISHED), nono (unless
# sandbox bypassed).  Soft tools: uv (missing alone never hard-fails).
# Usage: _missing_required_tools [check_uv]
_missing_required_tools() {
  local check_uv="${1:-0}"
  local missing_any=0

  # dotnet (hard when not published)
  if (( ! HAS_PUBLISHED )) && ! command -v dotnet >/dev/null 2>&1; then
    missing_any=1
  fi

  # nono (hard when sandbox enabled)
  if ! _read_bypass_sandbox && ! command -v nono >/dev/null 2>&1; then
    missing_any=1
  fi

  # uv (soft — missing alone never blocks; backend degrades gracefully)
  if (( check_uv )) && ! command -v uv >/dev/null 2>&1; then
    missing_any=1
  fi

  if (( ! missing_any )); then
    return 0
  fi

  # Already re-entered? Fall through to per-tool errors — no loop.
  if [[ -n "${VISUAL_RELAY_NIX_REENTRY:-}" ]]; then
    return 0
  fi

  # Probe nix (same order as _find_nix, Determinate-Nix-friendly).
  local nix_bin; nix_bin="$(_find_nix)"
  if [[ -n "$nix_bin" ]]; then
    echo "visual-relay: missing required tools; entering nix develop for this command" >&2
    exec env -u DOTNET_ROOT VISUAL_RELAY_NIX_REENTRY=1 ORIGINAL_CWD="$ORIGINAL_CWD" \
      "$nix_bin" develop --command bash "$0" "$cmd" ${ARGS:+"${ARGS[@]}"}
  fi

  # No nix — fall through to per-tool error messages.
  return 0
}

# ---------- nono sandbox prerequisite ----------

# Returns 0 (bypassed) if sandbox is not required, 1 (enabled) if nono is
# required.  Reads bypassSandbox from $SCRIPT_DIR/.relay/config.json.  When the
# file exists and bypassSandbox is absent or false, the default is enabled
# (matching RelayConfig.BypassSandbox = false).  When the file is missing
# entirely we also default to enabled — a fresh checkout should run sandboxed.
_read_bypass_sandbox() {
  if [[ -f "$SCRIPT_DIR/.relay/config.json" ]]; then
    # Explicit bypassSandbox:true → sandbox bypassed.
    if grep -q '"bypassSandbox"\s*:\s*true' "$SCRIPT_DIR/.relay/config.json" 2>/dev/null; then
      return 0  # bypass
    fi
    # Absent or false → sandbox enabled → nono required.
    return 1
  fi
  return 1  # no config file → sandbox enabled (matches C# BypassSandbox=false)
}

_require_nono() {
  if command -v nono >/dev/null 2>&1; then
    return 0
  fi

  _offer_nix_install || true

  cat >&2 <<'EOF'
visual-relay: nono sandbox is enabled but nono was not found on PATH.

  nono is a required dependency for the OS-level sandbox (Seatbelt on macOS,
  Landlock on Linux) that confines Swival writes and deletes to the workspace.
  Install nono:

    brew install nono
    (or see https://github.com/jedisct1/nono for other platforms)

  To run without the sandbox, set bypassSandbox:true in .relay/config.json.
  This is the only supported opt-out — there is no silent fallback to a
  weaker sandbox.
EOF
  exit 127
}

_provision_nono() {
  local xdg_config="${XDG_CONFIG_HOME:-$HOME/.config}"
  local profile_dir="${xdg_config}/nono/profiles"
  local profile_file="${profile_dir}/vr-guard.json"
  local source_profile="$SCRIPT_DIR/packaging/nono/vr-guard.json"

  # Pull the swival base profile pack (idempotent; no-op if already installed).
  # Network + one-time Sigstore trust verification (backend install already does
  # network work, so this fits the existing model).
  if command -v nono >/dev/null 2>&1; then
    if ! nono pull jedisct1/swival >/dev/null 2>&1; then
      echo "visual-relay: nono pull jedisct1/swival failed (network/Sigstore)" >&2
      echo "  The vr-guard profile extends swival; nono may error if swival is absent." >&2
      echo "  Retry with: nono pull jedisct1/swival" >&2
    fi
  fi

  mkdir -p "$profile_dir"

  # Install vr-guard.json only if missing — never clobber user edits.
  if [[ -f "$profile_file" ]]; then
    return 0
  fi

  if [[ -f "$source_profile" ]]; then
    cp "$source_profile" "$profile_file"
  fi
}

# ---------- watchdog ----------
_timeout_watchdog() {
  local timeout_secs="${VISUAL_RELAY_TEST_TIMEOUT:-60}"
  local cmd_pid watchdog_pid cmd_rc
  local flag_file
  flag_file="$(mktemp 2>/dev/null || echo "/tmp/.visual-relay-watchdog-$$")"

  # Launch the real command in its own process group so we can kill the whole
  # tree (dotnet → testhost → tests) on timeout.
  set -m
  "$@" &
  cmd_pid=$!

  # Background timer: when it expires, check whether the command is still alive
  # and kill the process group if so.  Writes a flag file so the main function
  # always exits non-zero on timeout even when the killed process handles
  # SIGTERM by exiting 0 (dotnet does this).
  (
    sleep "$timeout_secs"
    if kill -0 "$cmd_pid" 2>/dev/null; then
      echo "timed out" > "$flag_file"
      echo "visual-relay: test timed out after ${timeout_secs}s" >&2
      echo "  See TROUBLESHOOTING.md for diagnosing hangs." >&2
      echo "  To find which test is stuck: ./visual-relay test --blame-hang --blame-hang-timeout 30s" >&2
      echo "  Override timeout: VISUAL_RELAY_TEST_TIMEOUT=<seconds> ./visual-relay test" >&2
      kill -TERM -- -"$cmd_pid" 2>/dev/null || true
      sleep 1
      kill -KILL -- -"$cmd_pid" 2>/dev/null || true
    fi
  ) &
  watchdog_pid=$!

  # Wait for the command (not the watchdog).
  cmd_rc=0
  wait "$cmd_pid" 2>/dev/null || cmd_rc=$?

  # Tear down the watchdog timer AND its 'sleep' child. Under 'set -m' the timer
  # subshell is its own process-group leader, so kill the whole group (negative
  # PID). A bare 'kill "$watchdog_pid"' only signals the subshell leader and can
  # lose a race in which the subshell has already forked 'sleep': that 'sleep' is
  # then orphaned and, because it inherited this function's stdout/stderr, keeps
  # the pipe open until the timeout elapses. Any caller capturing output (CI,
  # $(...), the relay's ProcessCapture) would block for the full timeout even
  # though the command already finished.
  # Kill direct children first (pkill -P) so 'sleep' is reaped even when
  # set -m didn't establish a process group (non-interactive shells); then
  # kill the process group (or just the process as a fallback).
  pkill -P "$watchdog_pid" 2>/dev/null || true
  kill -- -"$watchdog_pid" 2>/dev/null || kill "$watchdog_pid" 2>/dev/null || true
  wait "$watchdog_pid" 2>/dev/null || true

  # If the watchdog fired, override the exit code.  Some programs (dotnet)
  # catch SIGTERM and exit 0, which would hide the timeout.
  if [[ -s "$flag_file" ]]; then
    cmd_rc=124   # GNU timeout convention
  fi
  rm -f "$flag_file"

  return "$cmd_rc"
}

# ---------- dispatch ----------
_ensure_devshell

case "$cmd" in
  launch|run)
    # Unified prerequisite gate: re-enter nix develop once if any hard tool
    # (dotnet when not published, nono when sandbox enabled) or uv is missing.
    _missing_required_tools 1
    # Nono sandbox guard and provisioning (runs before any backend work).
    if ! _read_bypass_sandbox; then
      _require_nono
      _provision_nono
    fi
    # Best-effort: bring the local model backend up before launching so a fresh
    # launch can run a task without a manual proxy step. Idempotent and fast
    # when already healthy; if it fails (e.g. litellm not installed) the launch
    # still proceeds and the in-app pre-flight probe surfaces the down backend.
    "$SCRIPT_DIR/tools/backend/backend.sh" start || \
      echo "visual-relay: backend start failed; launching anyway (in-app probe will flag a down backend)" >&2
    if (( HAS_PUBLISHED )); then
      exec "$PUBLISHED_APP" "$@"
    fi
    _require_dotnet
    dotnet run --project "$SCRIPT_DIR/src/VisualRelay.App/VisualRelay.App.csproj" -- "$@"
    ;;
  build)
    _require_dotnet
    "$SCRIPT_DIR/tools/guards/guard-source-enumeration.sh"
    dotnet build "$SCRIPT_DIR/VisualRelay.slnx" -m:1 -p:UseSharedCompilation=false "$@"
    ;;
  test)
    _require_dotnet
    _timeout_watchdog dotnet test "$SCRIPT_DIR/tests/VisualRelay.Tests/VisualRelay.Tests.csproj" -m:1 -p:UseSharedCompilation=false "$@"
    ;;
  format)
    _require_dotnet
    dotnet format "$SCRIPT_DIR/VisualRelay.slnx" "$@"
    ;;
  screenshot)
    _require_dotnet
    dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj" -- "$SCRIPT_DIR/docs/images/visual-relay-main.png"
    dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj" -- "$SCRIPT_DIR/docs/images/visual-relay-compact.png" 1060 720
    ;;
  run-task)
    _missing_required_tools
    if ! _read_bypass_sandbox; then
      _require_nono
    fi
    _require_dotnet
    dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.RunTask/VisualRelay.RunTask.csproj" -- "$@"
    ;;
  init)
    if [[ -x "$PUBLISHED_INIT" ]]; then
      exec "$PUBLISHED_INIT" "$@"
    fi
    _require_dotnet
    if [[ $# -eq 0 ]]; then
      dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.Init/VisualRelay.Init.csproj" -- "$ORIGINAL_CWD"
    else
      dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.Init/VisualRelay.Init.csproj" -- "$@"
    fi
    ;;
  install-hooks)
    git config core.hooksPath "$SCRIPT_DIR/.githooks"
    chmod +x "$SCRIPT_DIR/.githooks/commit-msg" "$SCRIPT_DIR/.githooks/pre-commit" "$SCRIPT_DIR/tools/guards/check-file-size.sh" "$SCRIPT_DIR/visual-relay"
    ;;
  check)
    _require_dotnet
    "$SCRIPT_DIR/tools/guards/guard-source-enumeration.sh"
    "$SCRIPT_DIR/tools/guards/check-file-size.sh"
    dotnet format "$SCRIPT_DIR/VisualRelay.slnx" --verify-no-changes
    dotnet build "$SCRIPT_DIR/VisualRelay.slnx" -m:1 -p:UseSharedCompilation=false
    # InspectCode zero-findings gate — runs after a successful build.
    # Whole-repo warm run measured at ~12s with persistent caches; added to
    # the inner-loop check because it stays within an acceptable budget.
    "$SCRIPT_DIR/tools/guards/inspect-code.sh"
    # VISUAL_RELAY_CHECK_TEST_TIMEOUT default is 300s (5 min) — well above a
    # healthy full-suite run (~2 min) but caps a deadlocked suite (parallel-
    # headless Avalonia wedge) to single-digit minutes instead of 34+.
    # The operator can export VISUAL_RELAY_CHECK_TEST_TIMEOUT to override.
    # When the watchdog fires it prints the same actionable --blame-hang
    # guidance as the test) case, and exit code 124 fails the check gate.
    VISUAL_RELAY_TEST_TIMEOUT="${VISUAL_RELAY_CHECK_TEST_TIMEOUT:-300}" \
        _timeout_watchdog dotnet test "$SCRIPT_DIR/tests/VisualRelay.Tests/VisualRelay.Tests.csproj" -m:1 -p:UseSharedCompilation=false
    dotnet build "$SCRIPT_DIR/tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj" -m:1 -p:UseSharedCompilation=false
    dotnet run --no-build --project "$SCRIPT_DIR/tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj" -- "$SCRIPT_DIR/docs/images/visual-relay-main.png"
    dotnet run --no-build --project "$SCRIPT_DIR/tools/VisualRelay.Screenshots/VisualRelay.Screenshots.csproj" -- "$SCRIPT_DIR/docs/images/visual-relay-compact.png" 1060 720
    ;;
  gen-backend-config)
    if [[ -x "$PUBLISHED_GC" ]]; then
      exec "$PUBLISHED_GC" "$@"
    fi
    _require_dotnet
    dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.GenBackendConfig/VisualRelay.GenBackendConfig.csproj" -- "$@"
    ;;
  inspect)
    _require_dotnet
    "$SCRIPT_DIR/tools/guards/inspect-code.sh"
    ;;
  *)
    echo "usage: ./visual-relay [launch|build|test|format|screenshot|run-task|init|install-hooks|check|inspect|gen-backend-config]" >&2
    exit 2
    ;;
esac

# ── needs_dotnet summary (for test assertions) ─────────────────────────────
needs_dotnet=0
case "$cmd" in
  build|test|format|screenshot|run-task|check|inspect)
    needs_dotnet=1
    # build, test, check, format, screenshot, run-task, inspect (always require dotnet)
    ;;
  launch|run)
    (( HAS_PUBLISHED )) || needs_dotnet=1
    ;;
  init)
    [[ -x "$PUBLISHED_INIT" ]] || needs_dotnet=1
    ;;
  gen-backend-config)
    [[ -x "$PUBLISHED_GC" ]] || needs_dotnet=1
    ;;
esac
}
main "$@"; exit $?
