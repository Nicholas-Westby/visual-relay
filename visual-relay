#!/usr/bin/env bash
# visual-relay — pre-dotnet bootstrap.
#
# This launcher is intentionally tiny: it does ONLY the work that must happen
# before .NET exists — resolve its own directory, enter the nix devshell once
# (which provisions dotnet/nono/uv), and detect a published brew install — then
# exec the real CLI. EVERY subcommand's logic lives in C# (tools/VisualRelay.Cli):
# build/test/format/screenshot/run-task/init/check/inspect/gen-backend-config/
# guards/install-hooks, plus the prerequisite gates (nono, swival), the timeout
# watchdog, the weekly swival upgrade check, and the post-bootstrap half of
# launch. Keep this file ≤20 logic lines (enforced by `./visual-relay guards`);
# new behavior belongs in the CLI, not here.
#
# Wrapped in main() so bash parses all control flow before any subcommand runs:
# a subcommand that rewrites this file on disk (self-host) cannot corrupt the
# in-flight parse.
set -euo pipefail
main() {
# Resolve this script's real directory, following symlinks (brew installs).
SCRIPT_DIR="$(target="${BASH_SOURCE[0]}"; while [[ -L "$target" ]]; do d="$(cd -P "$(dirname "$target")" && pwd)"; target="$(readlink "$target")"; [[ "$target" != /* ]] && target="$d/$target"; done; cd -P "$(dirname "$target")" && pwd)"
cmd="${1:-launch}"; shift || true; ARGS=("$@")
# Telemetry opt-out + don't let bash-spawned Python write .pyc into a sandboxed
# stdlib dir (the .NET layer sets these in the real swival env too). SCRIPT_DIR +
# ORIGINAL_CWD are exported so the CLI knows the repo root and the caller's cwd.
export AVALONIA_TELEMETRY_OPTOUT=1 DOTNET_CLI_TELEMETRY_OPTOUT=1 MSBUILDDISABLENODEREUSE=1 PYTHONDONTWRITEBYTECODE=1 VISUAL_RELAY_SCRIPT_DIR="$SCRIPT_DIR" ORIGINAL_CWD="${ORIGINAL_CWD:-$PWD}"
# Published (self-contained) brew binaries: the .app bundle's inner exec (so
# macOS attaches the brand icon) or the bare exec. Present only in brew installs.
PUBLISHED_APP="$SCRIPT_DIR/app/VisualRelay.App"; PUBLISHED_APP_BUNDLE="$SCRIPT_DIR/app/VisualRelay.app/Contents/MacOS/VisualRelay.App"; HAS_PUBLISHED=0
{ [[ -x "$PUBLISHED_APP" ]] || [[ -x "$PUBLISHED_APP_BUNDLE" ]]; } && HAS_PUBLISHED=1
# nix binary locator (Determinate-Nix-friendly). Empty output ⇒ no nix.
_find_nix() { if [[ -n "${_VISUAL_RELAY_FAKE_NO_NIX:-}" ]]; then return 1; fi; command -v nix 2>/dev/null || { [[ -x /nix/var/nix/profiles/default/bin/nix ]] && echo /nix/var/nix/profiles/default/bin/nix; } || { [[ -x /run/current-system/sw/bin/nix ]] && echo /run/current-system/sw/bin/nix; }; }
# Consent-gated Determinate Nix install offer (no nix → ask on a TTY, else hint).
_offer_nix_install() { local h='curl -fsSL https://install.determinate.systems/nix | sh -s -- install'; if [[ ! -t 0 || ! -t 1 ]]; then printf 'visual-relay: install Determinate Nix:\n  %s\n' "$h" >&2; return 1; fi; printf 'visual-relay: required tools missing. Install Determinate Nix? [y/N] ' >&2; IFS= read -r a; case "$a" in [yY]|[yY][eE][sS]) eval "${VISUAL_RELAY_NIX_INSTALLER:-$h}"; unset _VISUAL_RELAY_FAKE_NO_NIX;; *) printf 'visual-relay: install Determinate Nix manually:\n  %s\n' "$h" >&2; return 1;; esac; }
# Always enter the nix devshell once (the canonical env); published installs ship
# their own runtime and skip it. On no-nix, offer the install then retry once.
_ensure_devshell() { if [[ -n "${VISUAL_RELAY_NIX_REENTRY:-}" ]] || (( HAS_PUBLISHED )); then return 0; fi; local nix; nix="$(_find_nix)" || true; if [[ -z "$nix" ]]; then _offer_nix_install || return 0; nix="$(_find_nix)" || true; [[ -z "$nix" ]] && return 0; fi; echo "visual-relay: entering nix develop for this command" >&2; exec env -u DOTNET_ROOT VISUAL_RELAY_NIX_REENTRY=1 ORIGINAL_CWD="$ORIGINAL_CWD" "$nix" develop --command bash "$0" "$cmd" ${ARGS:+"${ARGS[@]}"}; }
_ensure_devshell
# Brew fast path: launch the published app directly (no dotnet). Dev commands and
# the source-checkout launch fall through to the C# CLI via `dotnet run`.
if (( HAS_PUBLISHED )) && [[ "$cmd" == launch || "$cmd" == run ]]; then [[ -x "$PUBLISHED_APP_BUNDLE" ]] && exec "$PUBLISHED_APP_BUNDLE" "$@"; exec "$PUBLISHED_APP" "$@"; fi
exec dotnet run --project "$SCRIPT_DIR/tools/VisualRelay.Cli/VisualRelay.Cli.csproj" -- "$cmd" "$@"
}
main "$@"; exit $?
