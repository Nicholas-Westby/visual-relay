# Provider API keys for Visual Relay's local model backend (LiteLLM proxy).
#
# PRIMARY LOCATION (always writable, even for brew-installed copies):
#   ~/.config/visual-relay/.env
#   (or $XDG_CONFIG_HOME/visual-relay/.env when XDG_CONFIG_HOME is set)
#
# DEV-ONLY FALLBACK (source checkout):
#   cp .env.example .env   (repo-root .env, git-ignored)
#
# Resolution precedence: process env > user-level .env > repo .env
# An exported key overrides both files; the in-app key panel writes to the
# user-level path.
#
# The proxy (tools/backend/litellm-config.yaml) reads each key via
# os.environ/<KEY>; a request only fails if its specific provider key is
# missing, and the proxy still boots without any keys.
#
# tools/backend/backend.sh start loads keys from both locations automatically.

# Moonshot — backs the `frontier` tier (kimi-k2) and the kimi-k2 alias.
MOONSHOT_API_KEY=

# DeepSeek — backs the `balanced-kimi` and `cheap-kimi` tiers (DeepSeek V4).
DEEPSEEK_API_KEY=

# Hugging Face Inference Providers — one token, many upstreams. Backs the
# `vision` tier and the hf-qwen3-coder-next alias.
HF_TOKEN=

# Anthropic — backs the `claude` tier (claude-opus-1m / claude-sonnet).
ANTHROPIC_API_KEY=

# OpenAI — backs the gpt-5 alias.
OPENAI_API_KEY=
