# Provider API keys for Visual Relay's local model backend (LiteLLM proxy).
#
# Copy this file to .env and fill in only the keys for providers you actually
# use. .env is git-ignored, so no secrets are committed. The proxy
# (tools/backend/litellm-config.yaml) reads each key via os.environ/<KEY>; a
# request only fails if its specific provider key is missing, and the proxy
# still boots without any keys.
#
#   cp .env.example .env
#
# tools/backend/backend.sh start sources this .env automatically.

# Moonshot — backs the `frontier` tier (kimi-k2) and the kimi-k2 alias.
MOONSHOT_API_KEY=

# DeepSeek — backs the `balanced-kimi` and `cheap-kimi` tiers (DeepSeek V4).
DEEPSEEK_API_KEY=

# Hugging Face Inference Providers — one token, many upstreams. Backs the
# `vision` tier and the hf-qwen3-coder-next alias.
HF_TOKEN=

# Anthropic — backs the `claude` tier (claude-opus-1m / claude-sonnet).
ANTHROPIC_API_KEY=

# OpenAI — backs the gpt-5 alias.
OPENAI_API_KEY=
