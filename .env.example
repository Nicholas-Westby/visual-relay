# Provider API keys for Visual Relay's local model backend (LiteLLM proxy).
#
# Location: ~/.config/visual-relay/.env
#   (or $XDG_CONFIG_HOME/visual-relay/.env when XDG_CONFIG_HOME is set)
#
# Resolution precedence: process env > user-level .env
# An exported key overrides the file; the in-app key panel writes to the
# user-level path.
#
# The proxy (tools/backend/litellm-config.yaml) reads each key via
# os.environ/<KEY>; a request only fails if its specific provider key is
# missing, and the proxy still boots without any keys.
#
# VisualRelay.Backend start loads keys from the user-level file automatically.

# Moonshot — backs the kimi-k2 alias (frontier fallback) and the kimi profile.
MOONSHOT_API_KEY=

# DeepSeek — backs the `balanced` and `cheap` tiers (DeepSeek V4).
DEEPSEEK_API_KEY=

# Hugging Face Inference Providers — one token, many upstreams. Backs the
# `frontier` tier (GLM 5.2 via Z.AI), the `vision` tier, and the
# hf-qwen3-coder-next alias.
HF_TOKEN=

# Anthropic — backs the `claude` tier (claude-opus-1m / claude-sonnet).
ANTHROPIC_API_KEY=

# OpenAI — backs the gpt-5 alias.
OPENAI_API_KEY=
