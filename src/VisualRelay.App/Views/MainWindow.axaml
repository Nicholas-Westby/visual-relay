<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualRelay.App.ViewModels"
        xmlns:domain="using:VisualRelay.Domain"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="820"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        x:Class="VisualRelay.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Visual Relay">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*"
          ColumnDefinitions="320,*,380"
          Background="#F5F6F3">
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Background="#FFFFFF"
                BorderBrush="#D8DED6"
                BorderThickness="0,0,0,1"
                Padding="12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="Root"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#243029"/>
                <TextBox Grid.Column="1"
                         Text="{Binding RootPath}"
                         PlaceholderText="Repository root"
                         MinHeight="36"/>
                <Button Grid.Column="2"
                        Command="{Binding BrowseCommand}"
                        Content="Browse"/>
                <Button Grid.Column="3"
                        Command="{Binding RefreshCommand}"
                        Content="Refresh"/>
                <Button Grid.Column="4"
                        Command="{Binding DrainQueueCommand}"
                        Content="Drain"/>
                <Button Grid.Column="5"
                        Command="{Binding PauseCommand}"
                        Content="Pause"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#D8DED6"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Row="0"
                      ColumnDefinitions="*,Auto,Auto"
                      Margin="12"
                      ColumnSpacing="6">
                    <TextBlock Text="Queue"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#243029"/>
                    <Button Grid.Column="1"
                            Command="{Binding MoveUpCommand}"
                            Content="Up"/>
                    <Button Grid.Column="2"
                            Command="{Binding MoveDownCommand}"
                            Content="Down"/>
                </Grid>

                <ListBox Grid.Row="1"
                         Margin="8,0,8,8"
                         ItemsSource="{Binding Tasks}"
                         SelectedItem="{Binding SelectedTask}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type domain:RelayTaskItem}">
                            <Grid RowDefinitions="Auto,Auto"
                                  Margin="4"
                                  MinHeight="52">
                                <TextBlock Text="{Binding Id}"
                                           FontWeight="SemiBold"
                                           Foreground="#18201B"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding MarkdownPath}"
                                           FontSize="11"
                                           Foreground="#677169"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        BorderBrush="#D8DED6"
                        BorderThickness="0,1,0,0"
                        Padding="12">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#38513F"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Grid.Column="1"
              RowDefinitions="2*,*"
              Margin="12"
              RowSpacing="12">
            <Border Background="#FFFFFF"
                    BorderBrush="#D8DED6"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid RowDefinitions="Auto,*">
                    <Grid Row="0"
                          ColumnDefinitions="*,Auto"
                          Margin="12">
                        <TextBlock Text="Task"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#243029"/>
                        <Button Grid.Column="1"
                                Command="{Binding RunSelectedCommand}"
                                Content="Run selected"/>
                    </Grid>
                    <TabControl Grid.Row="1"
                                Margin="8,0,8,8">
                        <TabItem Header="Markdown">
                            <ScrollViewer Padding="8">
                                <TextBlock Text="{Binding SelectedTaskMarkdown}"
                                           FontFamily="Menlo,Consolas,monospace"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Context">
                            <ScrollViewer Padding="8">
                                <TextBlock Text="{Binding SelectedTaskContext}"
                                           FontFamily="Menlo,Consolas,monospace"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#D8DED6"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Stages"
                               Margin="12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#243029"/>
                    <ItemsControl Grid.Row="1"
                                  Margin="8,0,8,8"
                                  ItemsSource="{Binding Stages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:StageRowViewModel}">
                                <Border Margin="4"
                                        Padding="8"
                                        BorderBrush="#D8DED6"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Background="#FAFBF7">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <TextBlock Text="{Binding Number}"
                                                   FontSize="11"
                                                   Foreground="#6F5B26"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#18201B"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Status}"
                                                   FontSize="12"
                                                   Foreground="#38513F"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Grid.Column="2"
              RowDefinitions="*,*"
              Margin="0,12,12,12"
              RowSpacing="12">
            <Border Background="#FFFFFF"
                    BorderBrush="#D8DED6"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Run log"
                               Margin="12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#243029"/>
                    <ListBox Grid.Row="1"
                             Margin="8,0,8,8"
                             ItemsSource="{Binding Events}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type domain:RelayEvent}">
                                <Grid RowDefinitions="Auto,Auto"
                                      Margin="4">
                                    <TextBlock Text="{Binding EventName}"
                                               FontWeight="SemiBold"
                                               Foreground="#18201B"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Level}"
                                               FontSize="12"
                                               Foreground="#677169"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#D8DED6"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="LLM commands"
                               Margin="12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#243029"/>
                    <ListBox Grid.Row="1"
                             Margin="8,0,8,8"
                             ItemsSource="{Binding TraceEntries}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type domain:TraceEntry}">
                                <Grid RowDefinitions="Auto,Auto"
                                      Margin="4">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Foreground="#18201B"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Content}"
                                               FontFamily="Menlo,Consolas,monospace"
                                               FontSize="12"
                                               Foreground="#47524A"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
