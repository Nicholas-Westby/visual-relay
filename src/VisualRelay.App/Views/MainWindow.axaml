<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualRelay.App.ViewModels"
        xmlns:controls="using:VisualRelay.App.Views.Controls"
        xmlns:buttons="using:VisualRelay.App.Views.Controls.Buttons"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="900"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        x:Class="VisualRelay.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.ico"
        Title="{Binding WindowTitle}"
        Background="#0C0E12">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*"
        Background="#0C0E12">
    <controls:TopBar Grid.Row="0"/>

    <Border Grid.Row="1"
            Background="#3A1518"
            BorderBrush="#7A2A30"
            BorderThickness="0,0,0,1"
            Padding="10,6"
            IsVisible="{Binding !IsBackendReachable}">
      <TextBlock Text="{Binding BackendStatusMessage}"
                 FontSize="12"
                 Foreground="#F2B8BC"
                 TextWrapping="Wrap"/>
    </Border>

    <Grid Grid.Row="2"
          x:Name="ContentGrid"
          ColumnSpacing="10"
          Margin="10,16,10,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="340"
                          MaxWidth="1200"/>
      </Grid.ColumnDefinitions>
      <!-- Left column: Queue or collapsed rail (content-swap in Auto track) -->
      <Panel Grid.Column="0">
        <controls:QueuePanel Width="280"
                             IsVisible="{Binding !IsQueueCollapsed}"/>
        <Border Width="36"
                Classes="rail"
                IsVisible="{Binding IsQueueCollapsed}">
          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      Margin="0">
            <buttons:IconButton IconStyle="CollapseToggle"
                                 ChevronDirection="{Binding QueueRailChevron}"
                                 Command="{Binding ToggleQueueCommand}"
                                 ToolTip.Tip="Expand Queue"/>
            <LayoutTransformControl>
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="90"/>
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Classes="railTitle"
                         Text="QUEUE"
                         TextAlignment="Center"/>
            </LayoutTransformControl>
          </StackPanel>
        </Border>
      </Panel>

      <Grid Grid.Column="1"
            x:Name="CenterGrid"
            RowDefinitions="1.45*,*"
            RowSpacing="10">
        <controls:TaskDetailPanel/>
        <controls:StageBoard Grid.Row="1"/>
      </Grid>

      <!-- Activity-column resizer: lives at the LEFT edge of the ACTIVITY column
           (Grid.Column="2") so its grab strip sits ON the visible seam rather than
           ColumnSpacing-offset to the left of it. PreviousAndCurrent makes the drag
           grow/shrink the ACTIVITY column (and the centre * column) — the same
           ColumnDefinitions[2] the code-behind clamps and persists. A 10px hit area,
           a faint divider line + centred grip, a :pointerover highlight and an
           explicit SizeWestEast cursor make it read as, and reliably act as, a
           drag handle. -->
      <GridSplitter x:Name="ActivitySplitter"
                     Grid.Column="2"
                     Width="20"
                     Margin="-15,0,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Stretch"
                     ResizeDirection="Columns"
                     ResizeBehavior="PreviousAndCurrent"
                     Background="Transparent"
                     Cursor="SizeWestEast"
                     ZIndex="1"
                     IsVisible="{Binding !IsActivityColumnCollapsed}">
        <GridSplitter.Styles>
          <!-- A faint full-height divider line centred on the seam plus a short
               centred grip; both brighten to the accent on :pointerover. The 10px
               hit strip straddles the seam (Margin=-5) so the grab area matches the
               line the user aims at. -->
          <Style Selector="GridSplitter">
            <Setter Property="Template">
               <ControlTemplate>
                 <Panel Background="{TemplateBinding Background}">
                   <Border Name="SeamLine"
                           Width="4"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Stretch">
                     <Border.Background>
                       <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                         <GradientStop Offset="0"    Color="#00252A33"/>
                         <GradientStop Offset="0.15" Color="#252A33"/>
                         <GradientStop Offset="0.85" Color="#252A33"/>
                         <GradientStop Offset="1"    Color="#00252A33"/>
                       </LinearGradientBrush>
                     </Border.Background>
                   </Border>
                   <StackPanel HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Spacing="4">
                     <Border Name="GripDot1"
                             Classes="gripDot"
                             Width="6"
                             Height="6"
                             CornerRadius="2"
                             Background="#46535F"/>
                     <Border Name="GripDot2"
                             Classes="gripDot"
                             Width="6"
                             Height="6"
                             CornerRadius="2"
                             Background="#46535F"/>
                     <Border Name="GripDot3"
                             Classes="gripDot"
                             Width="6"
                             Height="6"
                             CornerRadius="2"
                             Background="#46535F"/>
                   </StackPanel>
                 </Panel>
              </ControlTemplate>
            </Setter>
          </Style>
          <Style Selector="GridSplitter:pointerover /template/ Border#SeamLine">
            <Setter Property="Background">
              <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                  <GradientStop Offset="0"    Color="#003191FF"/>
                  <GradientStop Offset="0.15" Color="#3191FF"/>
                  <GradientStop Offset="0.85" Color="#3191FF"/>
                  <GradientStop Offset="1"    Color="#003191FF"/>
                </LinearGradientBrush>
              </Setter.Value>
            </Setter>
          </Style>
          <Style Selector="GridSplitter:pointerover /template/ Border.gripDot">
            <Setter Property="Background" Value="#5B9CFF"/>
          </Style>
        </GridSplitter.Styles>
      </GridSplitter>

      <!-- Right column: ActivityColumn or collapsed rail (content-swap in Auto track) -->
      <Panel Grid.Column="2">
        <controls:ActivityColumn x:Name="ActivityColumn"
                                  IsVisible="{Binding !IsActivityColumnCollapsed}"/>
        <Border Width="36"
                Classes="rail"
                IsVisible="{Binding IsActivityColumnCollapsed}">
          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      Margin="0">
            <buttons:IconButton IconStyle="CollapseToggle"
                                 ChevronDirection="{Binding ActivityRailChevron}"
                                 Command="{Binding ToggleActivityColumnCommand}"
                                 ToolTip.Tip="Expand Activity"/>
            <LayoutTransformControl>
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="90"/>
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Classes="railTitle"
                         Text="ACTIVITY"
                         TextAlignment="Center"/>
            </LayoutTransformControl>
          </StackPanel>
        </Border>
      </Panel>
    </Grid>
  </Grid>
</Window>
