<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualRelay.App.ViewModels"
        xmlns:controls="using:VisualRelay.App.Views.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="900"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        x:Class="VisualRelay.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.ico"
        Title="{Binding WindowTitle}"
        Background="#0C0E12">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*"
        Background="#0C0E12">
    <controls:TopBar Grid.Row="0"/>

    <Border Grid.Row="1"
            Background="#3A1518"
            BorderBrush="#7A2A30"
            BorderThickness="0,0,0,1"
            Padding="10,6"
            IsVisible="{Binding !IsBackendReachable}">
      <TextBlock Text="{Binding BackendStatusMessage}"
                 FontSize="12"
                 Foreground="#F2B8BC"
                 TextWrapping="Wrap"/>
    </Border>

    <Grid Grid.Row="2"
          x:Name="ContentGrid"
          ColumnSpacing="10"
          Margin="10,16,10,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="340"
                          MinWidth="300"
                          MaxWidth="1200"/>
      </Grid.ColumnDefinitions>
      <!-- Left column: Queue or collapsed rail (content-swap in Auto track) -->
      <Panel Grid.Column="0">
        <controls:QueuePanel Width="280"
                             IsVisible="{Binding !IsQueueCollapsed}"/>
        <Border Width="36"
                Classes="rail"
                IsVisible="{Binding IsQueueCollapsed}">
          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      Margin="0">
            <Button Classes="collapseToggle"
                    Command="{Binding ToggleQueueCommand}"
                    ToolTip.Tip="Expand Queue">
              <controls:ChevronIcon Direction="{Binding QueueRailChevron}"/>
            </Button>
            <LayoutTransformControl>
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="90"/>
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Classes="railTitle"
                         Text="QUEUE"
                         TextAlignment="Center"/>
            </LayoutTransformControl>
          </StackPanel>
        </Border>
      </Panel>

      <Grid Grid.Column="1"
            x:Name="CenterGrid"
            RowDefinitions="1.45*,*"
            RowSpacing="10">
        <controls:TaskDetailPanel/>
        <controls:StageBoard Grid.Row="1"/>
      </Grid>

      <GridSplitter x:Name="ActivitySplitter"
                     Grid.Column="1"
                     Width="3"
                     Background="Transparent"
                     HorizontalAlignment="Right"
                     IsVisible="{Binding !IsActivityColumnCollapsed}"/>

      <!-- Right column: ActivityColumn or collapsed rail (content-swap in Auto track) -->
      <Panel Grid.Column="2">
        <controls:ActivityColumn x:Name="ActivityColumn"
                                  IsVisible="{Binding !IsActivityColumnCollapsed}"/>
        <Border Width="36"
                Classes="rail"
                IsVisible="{Binding IsActivityColumnCollapsed}">
          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      Margin="0">
            <Button Classes="collapseToggle"
                    Command="{Binding ToggleActivityColumnCommand}"
                    ToolTip.Tip="Expand Activity">
              <controls:ChevronIcon Direction="{Binding ActivityRailChevron}"/>
            </Button>
            <LayoutTransformControl>
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="90"/>
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Classes="railTitle"
                         Text="ACTIVITY"
                         TextAlignment="Center"/>
            </LayoutTransformControl>
          </StackPanel>
        </Border>
      </Panel>
    </Grid>
  </Grid>
</Window>
