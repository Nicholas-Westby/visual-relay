<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualRelay.App.ViewModels"
        xmlns:domain="using:VisualRelay.Domain"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="820"
        Width="1280"
        Height="820"
        MinWidth="960"
        MinHeight="680"
        x:Class="VisualRelay.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Visual Relay">

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#CBD5E1"/>
      <Setter Property="Foreground" Value="#0F172A"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="BorderBrush" Value="#2563EB"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>
    <Style Selector="Button.subtle">
      <Setter Property="Background" Value="#EEF2F7"/>
      <Setter Property="BorderBrush" Value="#EEF2F7"/>
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
  </Window.Styles>

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*"
        ColumnDefinitions="260,*,320"
        Background="#F6F8FB">
    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
          <TextBlock Text="Visual Relay"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"/>
          <TextBlock Text="LLM task control room"
                     FontSize="11"
                     Foreground="#64748B"/>
        </StackPanel>

        <Border Grid.Column="1"
                Background="#F8FAFC"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8"
                ClipToBounds="True">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
            <TextBlock Text="Folder"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#475569"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding RootDisplayPath}"
                       Foreground="#0F172A"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <Button Grid.Column="2"
                Classes="primary"
                Command="{Binding BrowseCommand}"
                Content="Choose Folder"/>
        <Button Grid.Column="3"
                Classes="subtle"
                Command="{Binding RefreshCommand}"
                Content="Refresh"/>
        <Button Grid.Column="4"
                Classes="subtle"
                Command="{Binding DrainQueueCommand}"
                Content="Drain"/>
        <Button Grid.Column="5"
                Classes="subtle"
                Command="{Binding PauseCommand}"
                Content="Pause"/>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">
        <Grid Row="0"
              ColumnDefinitions="*,Auto,Auto"
              Margin="16,16,16,10"
              ColumnSpacing="6">
          <TextBlock Text="Queue"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"/>
          <Button Grid.Column="1"
                  Classes="subtle"
                  Command="{Binding MoveUpCommand}"
                  Content="↑"/>
          <Button Grid.Column="2"
                  Classes="subtle"
                  Command="{Binding MoveDownCommand}"
                  Content="↓"/>
        </Grid>

        <ListBox Grid.Row="1"
                 Margin="10,0,10,10"
                 ItemsSource="{Binding Tasks}"
                 SelectedItem="{Binding SelectedTask}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type domain:RelayTaskItem}">
              <Border Margin="2"
                      Padding="10"
                      MinHeight="62"
                      Background="#F8FAFC"
                      BorderBrush="#E2E8F0"
                      BorderThickness="1"
                      CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto">
                  <TextBlock Text="{Binding Id}"
                             FontWeight="SemiBold"
                             Foreground="#0F172A"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding MarkdownPath}"
                             FontSize="11"
                             Foreground="#64748B"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2"
                BorderBrush="#E2E8F0"
                BorderThickness="0,1,0,0"
                Padding="16,12">
          <TextBlock Text="{Binding StatusText}"
                     Foreground="#166534"
                     MaxLines="2"
                     TextTrimming="CharacterEllipsis"/>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="2*,*"
          Margin="14"
          RowSpacing="14">
      <Border Background="#FFFFFF"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <Grid Row="0"
                ColumnDefinitions="*,Auto"
                Margin="16,14,16,0">
            <TextBlock Text="Task"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <Button Grid.Column="1"
                    Classes="primary"
                    Command="{Binding RunSelectedCommand}"
                    Content="Run selected"/>
          </Grid>
          <TabControl Grid.Row="1"
                      Margin="12,2,12,12">
            <TabItem Header="Markdown">
              <ScrollViewer Padding="10">
                <TextBlock Text="{Binding SelectedTaskMarkdown}"
                           FontFamily="Menlo,Consolas,monospace"
                           FontSize="13"
                           Foreground="#0F172A"
                           TextWrapping="Wrap"/>
              </ScrollViewer>
            </TabItem>
            <TabItem Header="Context">
              <ScrollViewer Padding="10">
                <TextBlock Text="{Binding SelectedTaskContext}"
                           FontFamily="Menlo,Consolas,monospace"
                           FontSize="13"
                           Foreground="#0F172A"
                           TextWrapping="Wrap"/>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Background="#FFFFFF"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="Stages"
                     Margin="16,14,16,8"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"/>
          <ScrollViewer Grid.Row="1" Margin="12,0,12,12">
            <ItemsControl ItemsSource="{Binding Stages}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:StageRowViewModel}">
                  <Border Margin="4"
                          Padding="8"
                          MinHeight="66"
                          BorderBrush="#E2E8F0"
                          BorderThickness="1"
                          CornerRadius="8"
                          Background="#F8FAFC">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBlock Text="{Binding Number}"
                                 FontSize="11"
                                 Foreground="#B45309"/>
                      <TextBlock Grid.Row="1"
                                 Text="{Binding Name}"
                                 FontWeight="SemiBold"
                                 Foreground="#0F172A"
                                 MaxLines="1"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Row="2"
                                 Text="{Binding Status}"
                                 FontSize="12"
                                 Foreground="#166534"
                                 MaxLines="1"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="1"
          Grid.Column="2"
          RowDefinitions="*,*"
          Margin="0,14,14,14"
          RowSpacing="14">
      <Border Background="#FFFFFF"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="Run log"
                     Margin="16,14,16,8"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"/>
          <ListBox Grid.Row="1"
                   Margin="10,0,10,10"
                   ItemsSource="{Binding Events}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type domain:RelayEvent}">
                <Grid RowDefinitions="Auto,Auto" Margin="6">
                  <TextBlock Text="{Binding EventName}"
                             FontWeight="SemiBold"
                             Foreground="#0F172A"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding Level}"
                             FontSize="12"
                             Foreground="#64748B"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Background="#FFFFFF"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              CornerRadius="10">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="LLM commands"
                     Margin="16,14,16,8"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Foreground="#0F172A"/>
          <ListBox Grid.Row="1"
                   Margin="10,0,10,10"
                   ItemsSource="{Binding TraceEntries}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type domain:TraceEntry}">
                <Grid RowDefinitions="Auto,Auto" Margin="6">
                  <TextBlock Text="{Binding Title}"
                             FontWeight="SemiBold"
                             Foreground="#0F172A"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Row="1"
                             Text="{Binding Content}"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="12"
                             Foreground="#475569"
                             TextWrapping="Wrap"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
