<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:controls="using:VisualRelay.App.Views.Controls"
             xmlns:core="using:VisualRelay.Core.Execution"
             x:Class="VisualRelay.App.Views.Controls.SandboxPaths"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">
  <StackPanel Spacing="6">

    <!-- Loading state — shown only while the async nono calls are in flight -->
    <TextBlock Text="Loading sandbox paths…"
               FontSize="12" Foreground="#9AA3B1"
               IsVisible="{Binding IsSandboxInfoLoading}"/>

    <!-- Post-load states — hidden while loading so empty buckets never flash -->
    <StackPanel Spacing="6"
                IsVisible="{Binding IsSandboxInfoLoading, Converter={x:Static controls:BoolNotConverter.Instance}}">

      <!-- Unavailable state -->
      <Border Background="#12151C" BorderBrush="#252A33" BorderThickness="1"
              CornerRadius="4" Padding="10"
              IsVisible="{Binding IsSandboxInfoAvailable, Converter={x:Static controls:BoolNotConverter.Instance}}">
        <TextBlock Text="Sandbox path information is unavailable (nono not found or failed to respond)."
                   FontSize="12" Foreground="#9AA3B1" TextWrapping="Wrap"/>
      </Border>

      <!-- Available state -->
      <StackPanel Spacing="6"
                  IsVisible="{Binding IsSandboxInfoAvailable}">

        <!-- Explanation -->
        <TextBlock Text="Reads: the whole filesystem except the blocked paths. Writes: only the paths listed here (plus the current workspace)."
                   FontSize="11" Foreground="#9AA3B1" TextWrapping="Wrap"
                   Margin="0,0,0,2"/>

        <!-- Writable paths -->
        <Border Background="#12151C" BorderBrush="#252A33" BorderThickness="1"
                CornerRadius="4" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock Text="Writable" FontSize="13" FontWeight="Bold"
                       Foreground="#5AD47D"/>
            <ItemsControl ItemsSource="{Binding SandboxWritablePaths}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="2"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="core:SandboxPathEntry">
                  <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="6">
                    <Ellipse Width="8" Height="8" Fill="#5AD47D"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Raw}"
                               FontSize="12" Foreground="#E7ECF3"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Expanded}"/>
                    <TextBlock Grid.Column="2" Text="{Binding Source}"
                               FontSize="11" Foreground="#7F8794"
                               VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Readable paths -->
        <Border Background="#12151C" BorderBrush="#252A33" BorderThickness="1"
                CornerRadius="4" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock Text="Readable" FontSize="13" FontWeight="Bold"
                       Foreground="#F2F5FA"/>
            <ItemsControl ItemsSource="{Binding SandboxReadablePaths}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="2"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="core:SandboxPathEntry">
                  <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="6">
                    <Ellipse Width="8" Height="8" Fill="#4A5568"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Raw}"
                               FontSize="12" Foreground="#E7ECF3"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Expanded}"/>
                    <TextBlock Grid.Column="2" Text="{Binding Source}"
                               FontSize="11" Foreground="#7F8794"
                               VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Blocked paths -->
        <Border Background="#12151C" BorderBrush="#252A33" BorderThickness="1"
                CornerRadius="4" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock Text="Blocked" FontSize="13" FontWeight="Bold"
                       Foreground="#E0556A"/>
            <ItemsControl ItemsSource="{Binding SandboxBlockedPaths}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="2"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="core:SandboxPathEntry">
                  <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="6">
                    <Ellipse Width="8" Height="8" Fill="#E0556A"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Raw}"
                               FontSize="12" Foreground="#E7ECF3"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Expanded}"/>
                    <TextBlock Grid.Column="2" Text="{Binding Source}"
                               FontSize="11" Foreground="#7F8794"
                               VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </StackPanel>
    </StackPanel>
  </StackPanel>
</UserControl>
