<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:buttons="using:VisualRelay.App.Views.Controls.Buttons"
             x:Class="VisualRelay.App.Views.Controls.ObsidianSettings"
             x:DataType="vm:MainWindowViewModel"
             x:Name="Root">
  <StackPanel Spacing="2">
    <CheckBox IsChecked="{Binding ObsidianEnabled}"
              Foreground="#E7ECF3" FontSize="12">
      Obsidian bridge — auto-import from iCloud vault
    </CheckBox>

    <TextBlock Text="Files in &quot;New Tasks/&quot; become tasks; summaries publish to &quot;Completed/&quot;"
               FontSize="11" Foreground="#9AA3B1"
               IsVisible="{Binding ObsidianEnabled}"
               TextWrapping="Wrap"/>

    <Grid ColumnDefinitions="*,Auto,Auto,100" ColumnSpacing="4"
          IsVisible="{Binding ObsidianEnabled}">
      <TextBox Grid.Column="0" Text="{Binding ObsidianVaultRoot, Mode=TwoWay}"
               FontSize="12" VerticalAlignment="Center"
               PlaceholderText="Vault root"/>
      <buttons:CommonButton Grid.Column="1" Content="Browse"
                            Command="{Binding BrowseVaultRootCommand}"/>
      <buttons:CommonButton Grid.Column="2" Content="Reveal"
                            Appearance="Path"
                            Command="{Binding RevealVaultRootCommand}"/>
      <StackPanel Grid.Column="3" Orientation="Horizontal"
                  VerticalAlignment="Center" Spacing="4">
        <TextBlock Text="60" FontSize="11" Foreground="#9AA3B1"
                   VerticalAlignment="Center"/>
        <TextBox Text="{Binding ObsidianPollSeconds, Mode=TwoWay}"
                 FontSize="12" VerticalAlignment="Center" Width="50"/>
      </StackPanel>
    </Grid>
  </StackPanel>
</UserControl>
