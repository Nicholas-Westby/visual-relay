<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.TaskDetailPanel"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">
      <Border Grid.Row="0"
              BorderBrush="#252A33"
              BorderThickness="0,0,0,1"
              Padding="16,14">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="TASK"
                     Classes="panelTitle"
                     VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="8">
            <Border Classes="chip"
                    MaxWidth="210">
              <TextBlock Text="{Binding StatusText}"
                         FontSize="11"
                         Foreground="#8FA6FF"
                         MaxLines="1"
                         TextTrimming="CharacterEllipsis"/>
            </Border>
            <Button Classes="primary"
                    Command="{Binding RunSelectedCommand}"
                    Content="Run selected"/>
          </StackPanel>
        </Grid>
      </Border>

      <TabControl Grid.Row="1"
                  Margin="16,4,16,16">
        <TabItem Header="Markdown">
          <ScrollViewer Padding="8,18,8,8"
                        HorizontalScrollBarVisibility="Disabled">
            <TextBlock Text="{Binding SelectedTaskMarkdown}"
                       FontFamily="Menlo,Consolas,monospace"
                       FontSize="13"
                       LineHeight="21"
                       Foreground="#DCE2EA"
                       TextWrapping="Wrap"/>
          </ScrollViewer>
        </TabItem>
        <TabItem Header="Context">
          <ScrollViewer Padding="8,18,8,8"
                        HorizontalScrollBarVisibility="Disabled">
            <TextBlock Text="{Binding SelectedTaskContext}"
                       FontFamily="Menlo,Consolas,monospace"
                       FontSize="13"
                       LineHeight="21"
                       Foreground="#DCE2EA"
                       TextWrapping="Wrap"/>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>
  </Border>
</UserControl>
