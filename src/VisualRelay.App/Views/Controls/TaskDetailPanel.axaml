<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.TaskDetailPanel"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">
      <Border Grid.Row="0"
              BorderBrush="#252A33"
              BorderThickness="0,0,0,1"
              Padding="16,14">
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="TASK"
                       Classes="panelTitle"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1"
                         Orientation="Horizontal"
                         Spacing="8">
              <Button Classes="collapseToggle"
                      Command="{Binding ToggleFocusCommand}"
                      Content="{Binding FocusButtonIcon}"
                      ToolTip.Tip="{Binding FocusButtonTooltip}"
                      VerticalAlignment="Center"/>
              <Border Classes="chip"
                       MaxWidth="220">
                <TextBlock Text="{Binding SelectedTaskMetricLabel}"
                            FontSize="11"
                            Foreground="#8FE3A2"
                            MaxLines="1"
                            TextTrimming="CharacterEllipsis"/>
              </Border>
              <Border Classes="chip"
                       MaxWidth="260">
                <TextBlock Text="{Binding StatusText}"
                            ToolTip.Tip="{Binding StatusText}"
                            FontSize="11"
                            Foreground="#8FA6FF"
                            MaxLines="1"
                            TextTrimming="CharacterEllipsis"/>
              </Border>
              <Button Classes="primary"
                       Command="{Binding RunSelectedCommand}"
                       Content="Run selected"/>
              <Button Classes="primary"
                       Command="{Binding ResumeSelectedCommand}"
                       Content="Resume"/>
            </StackPanel>
          </Grid>

          <Border Grid.Row="1"
                  IsVisible="{Binding IsViewingDifferentTaskDuringRun}"
                  Background="#17233D"
                  BorderBrush="#3191FF"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10,7">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">
              <TextBlock Text="{Binding ViewingRunContextText}"
                         Foreground="#C7D4FF"
                         FontSize="12"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         MaxLines="1"
                         TextTrimming="CharacterEllipsis"/>
              <Button Grid.Column="1"
                      Command="{Binding FollowRunningTaskCommand}"
                      Content="Follow"
                      Padding="10,4"
                      MinHeight="26"/>
            </Grid>
          </Border>

          <CheckBox Grid.Row="2"
                    IsChecked="{Binding SelectedTaskBoostsTurns}"
                    Content="{Binding TurnBudgetLabel}"
                    ToolTip.Tip="Use for unusually large tasks. Multiplies the default per-stage turn limit by 10 for this task only."
                    IsEnabled="{Binding CanToggleTurnBudget}"
                    FontSize="12"
                    Foreground="#C7D4FF"
                    VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1"
            RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                IsVisible="{Binding HasSelectedTaskError}"
                Background="#2A1715"
                BorderBrush="#F36F63"
                BorderThickness="1"
                CornerRadius="8"
                Margin="16,12,16,4"
                Padding="12,10"
                MaxHeight="160">
          <StackPanel Spacing="6">
            <TextBlock Text="LATEST RUN FAILED"
                       Foreground="#F36F63"
                       FontSize="11"
                       FontWeight="SemiBold"/>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
              <SelectableTextBlock Text="{Binding SelectedTaskError}"
                                   Foreground="#F4B5AE"
                                   FontFamily="Menlo,Consolas,monospace"
                                   FontSize="12"
                                   LineHeight="18"
                                   TextWrapping="Wrap"/>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="16,4,16,16"
                    SelectedIndex="{Binding SelectedTabIndex}">
          <TabItem Header="Markdown">
            <Grid RowDefinitions="Auto,*">
              <!-- Read-only toolbar -->
              <Border Grid.Row="0"
                      Padding="8,4"
                      IsVisible="{Binding IsMarkdownReadOnly}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Command="{Binding EditSelectedTaskCommand}"
                          Padding="10,4"
                          MinHeight="26"
                          Content="Edit"
                          ToolTip.Tip="{Binding EditBlockedReason}"/>
                  <TextBlock Text="{Binding EditBlockedReason}"
                             IsVisible="{Binding HasEditBlockedReason}"
                             FontSize="11"
                             Foreground="#F2C66D"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
              <!-- Edit toolbar -->
              <Border Grid.Row="0"
                      Padding="8,4"
                      IsVisible="{Binding IsEditingMarkdown}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Command="{Binding SaveEditCommand}"
                          Classes="primary"
                          Padding="10,4"
                          MinHeight="26"
                          Content="Save"/>
                  <Button Command="{Binding CancelEditCommand}"
                          Padding="10,4"
                          MinHeight="26"
                          Content="Cancel"/>
                </StackPanel>
              </Border>
              <!-- New-task toolbar -->
              <Border Grid.Row="0"
                      Padding="8,4"
                      IsVisible="{Binding IsNewTaskDialogOpen}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Command="{Binding CreateNewTaskCommand}"
                          Classes="primary"
                          Padding="10,4"
                          MinHeight="26"
                          Content="Create task"/>
                  <Button Command="{Binding OpenNewTaskDialogCommand}"
                          Padding="10,4"
                          MinHeight="26"
                          Content="Cancel"/>
                </StackPanel>
              </Border>

              <!-- Read-only view -->
              <ScrollViewer Grid.Row="1"
                            Padding="8,14,8,8"
                            HorizontalScrollBarVisibility="Disabled"
                            IsVisible="{Binding IsMarkdownReadOnly}">
                <TextBlock Text="{Binding SelectedTaskMarkdown}"
                           FontFamily="Menlo,Consolas,monospace"
                           FontSize="13"
                           LineHeight="21"
                           Foreground="#DCE2EA"
                           TextWrapping="Wrap"/>
              </ScrollViewer>

              <!-- Edit view -->
              <TextBox Grid.Row="1"
                       Text="{Binding EditBuffer}"
                       AcceptsReturn="True"
                       FontFamily="Menlo,Consolas,monospace"
                       FontSize="13"
                       Foreground="#DCE2EA"
                       Background="#141820"
                       BorderBrush="#2A303A"
                       BorderThickness="1"
                       TextWrapping="Wrap"
                       IsVisible="{Binding IsEditingMarkdown}"
                       Margin="4"/>

              <!-- New-task view -->
              <Grid Grid.Row="1"
                    RowDefinitions="Auto,*,Auto"
                    IsVisible="{Binding IsNewTaskDialogOpen}"
                    Margin="4">
                <TextBox Text="{Binding NewTaskTitle}"
                         PlaceholderText="Task title (required)"
                         FontFamily="Menlo,Consolas,monospace"
                         FontSize="13"
                         Foreground="#DCE2EA"
                         Background="#141820"
                         BorderBrush="#2A303A"
                         BorderThickness="1"
                         Margin="0,0,0,8"/>
                <TextBox Grid.Row="1"
                         Text="{Binding NewTaskBody}"
                         PlaceholderText="Initial markdown body (optional)"
                         AcceptsReturn="True"
                         FontFamily="Menlo,Consolas,monospace"
                         FontSize="13"
                         Foreground="#DCE2EA"
                         Background="#141820"
                         BorderBrush="#2A303A"
                         BorderThickness="1"
                         TextWrapping="Wrap"
                         Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2"
                           Text="{Binding NewTaskError}"
                           IsVisible="{Binding NewTaskError, Converter={x:Static ObjectConverters.IsNotNull}}"
                           FontSize="11"
                           Foreground="#F36F63"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
              </Grid>
            </Grid>
          </TabItem>
          <TabItem Header="Context">
            <ScrollViewer Padding="8,18,8,8"
                          HorizontalScrollBarVisibility="Disabled">
              <TextBlock Text="{Binding SelectedTaskContext}"
                         FontFamily="Menlo,Consolas,monospace"
                         FontSize="13"
                         LineHeight="21"
                         Foreground="#DCE2EA"
                         TextWrapping="Wrap"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Attachments">
            <Grid RowDefinitions="Auto,*">
              <Border Grid.Row="0"
                      Padding="8,8,8,4">
                <Button Command="{Binding AddAttachmentsCommand}"
                        Classes="primary"
                        Padding="10,4"
                        MinHeight="26"
                        Content="Add Attachment…"/>
              </Border>
              <ScrollViewer Grid.Row="1"
                            Padding="8,4,8,8"
                            HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="AttachmentList"
                              x:CompileBindings="False"
                              ItemsSource="{Binding SelectedTask.SiblingPaths}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="4,3"
                              Margin="0,0,0,2">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="6">
                          <TextBlock Text="{Binding}"
                                     FontFamily="Menlo,Consolas,monospace"
                                     FontSize="12"
                                     Foreground="#C8CED8"
                                     VerticalAlignment="Center"
                                     MaxLines="1"
                                     TextTrimming="CharacterEllipsis"/>
                          <Button Grid.Column="1"
                                  Command="{Binding $parent[UserControl].DataContext.RevealAttachmentCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="6,2"
                                  MinHeight="22"
                                  FontSize="11"
                                  Content="Reveal"/>
                          <Button Grid.Column="2"
                                  Command="{Binding $parent[UserControl].DataContext.RemoveAttachmentCommand}"
                                  CommandParameter="{Binding}"
                                  Padding="6,2"
                                  MinHeight="22"
                                  FontSize="11"
                                  Content="Remove"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>
  </Border>
</UserControl>
