<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.TopBar"
             x:DataType="vm:MainWindowViewModel">
  <Border Background="#101218"
          BorderBrush="#252A33"
          BorderThickness="0,0,0,1"
          Padding="10">
    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
          ColumnSpacing="10">
      <Grid ColumnDefinitions="36,Auto"
            ColumnSpacing="10"
            VerticalAlignment="Center"
            Margin="2,0,8,0">
        <Border Width="34"
                Height="34"
                CornerRadius="8"
                Background="#5575F2"
                BoxShadow="0 10 24 0 #665575F2">
          <TextBlock Text="VR"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontWeight="Bold"
                     Foreground="#FFFFFF"/>
        </Border>
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
          <TextBlock Text="Visual Relay"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#F2F5FA"/>
          <TextBlock Text="task pipeline"
                     FontSize="11"
                     Foreground="#7F8794"/>
        </StackPanel>
      </Grid>

      <Button Grid.Column="1"
              Classes="path"
              Command="{Binding BrowseCommand}">
        <Grid ColumnDefinitions="Auto,Auto,*"
              ColumnSpacing="10"
              ClipToBounds="True">
          <TextBlock Text="FOLDER"
                     FontSize="11"
                     FontWeight="Bold"
                     Foreground="#7F8794"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1"
                     Text="{Binding RootName}"
                     FontWeight="SemiBold"
                     Foreground="#E7ECF3"
                     MaxLines="1"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="2"
                     Text="{Binding RootParentPath}"
                     FontFamily="Menlo,Consolas,monospace"
                     FontSize="12"
                     Foreground="#9AA3B1"
                     MaxLines="1"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <Button Grid.Column="2"
              Command="{Binding RefreshCommand}"
              Content="Refresh"/>
      <Button Grid.Column="3"
              Classes="warning"
              Command="{Binding PauseCommand}"
              Content="Pause"/>
      <Button Grid.Column="4"
              Classes="primary"
              Command="{Binding DrainQueueCommand}"
              Content="Run All"/>
    </Grid>
  </Border>
</UserControl>
