<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.RewriteToolbar"
             x:DataType="vm:MainWindowViewModel">
  <StackPanel Orientation="Horizontal" Spacing="6">
    <!-- Idle: Rewrite with AI button, visible when eligible -->
    <Button Content="Rewrite with AI"
            Command="{Binding RewriteSelectedTaskCommand}"
            Padding="10,4"
            MinHeight="26"
            IsVisible="{Binding CanRewriteSelectedPublic}"/>

    <!-- Rewriting: spinner + elapsed + cancel, visible while rewriting -->
    <StackPanel Orientation="Horizontal"
                Spacing="6"
                IsVisible="{Binding IsSelectedTaskRewriting}">
      <ProgressBar IsIndeterminate="True"
                   Width="16"
                   Height="16"
                   VerticalAlignment="Center"/>
      <TextBlock Text="{Binding SelectedTaskRewriteElapsed}"
                 FontSize="11"
                 Foreground="#8FE3A2"
                 VerticalAlignment="Center"/>
      <Button Content="Cancel"
              Command="{Binding CancelRewriteSelectedCommand}"
              Padding="10,4"
              MinHeight="26"/>
    </StackPanel>

    <!-- Done with undo: Revert button -->
    <Button Content="Revert"
            Command="{Binding RevertRewriteSelectedCommand}"
            Padding="10,4"
            MinHeight="26"
            IsVisible="{Binding SelectedTaskHasRewriteUndo}"/>
  </StackPanel>
</UserControl>
