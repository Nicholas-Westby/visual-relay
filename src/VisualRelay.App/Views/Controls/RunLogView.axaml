<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:domain="using:VisualRelay.Domain"
             x:Class="VisualRelay.App.Views.Controls.RunLogView"
             x:DataType="vm:MainWindowViewModel">
  <ListBox Margin="12"
           ItemsSource="{Binding Events}">
    <ListBox.ItemTemplate>
      <DataTemplate DataType="{x:Type domain:RelayEvent}">
        <Grid RowDefinitions="Auto,Auto"
              Margin="0,0,0,10">
          <TextBlock Text="{Binding DisplayLine}"
                     ToolTip.Tip="{Binding DisplayLine}"
                     FontFamily="Menlo,Consolas,monospace"
                     FontWeight="SemiBold"
                     Foreground="#53B7F4"
                     MaxLines="1"
                     TextTrimming="CharacterEllipsis"/>
          <SelectableTextBlock Grid.Row="1"
                               Text="{Binding DetailLine}"
                               ToolTip.Tip="{Binding DetailLine}"
                               Classes="logDetail"
                               Classes.attention="{Binding IsAttention}"
                               FontFamily="Menlo,Consolas,monospace"
                               FontSize="12"
                               Foreground="#7F8794"/>
        </Grid>
      </DataTemplate>
    </ListBox.ItemTemplate>
  </ListBox>
</UserControl>
