<StackPanel xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:controls="using:VisualRelay.App.Views.Controls"
             x:Class="VisualRelay.App.Views.Controls.TaskActionBar"
             x:DataType="vm:MainWindowViewModel"
             Orientation="Horizontal"
             Spacing="8">
  <Button Classes="focusToggle"
          Command="{Binding ToggleFocusCommand}"
          ToolTip.Tip="{Binding FocusButtonTooltip}"
          VerticalAlignment="Center">
    <controls:FocusToggleIcon IsContracted="{Binding IsFocused}"/>
  </Button>
  <Border Classes="chip"
          MaxWidth="220">
    <TextBlock Text="{Binding SelectedTaskMetricLabel}"
               FontSize="11"
               Foreground="#8FE3A2"
               MaxLines="1"
               TextTrimming="CharacterEllipsis"/>
  </Border>
  <Border Classes="chip"
          MaxWidth="260">
    <TextBlock Text="{Binding StatusText}"
               ToolTip.Tip="{Binding StatusText}"
               FontSize="11"
               Foreground="#8FA6FF"
               MaxLines="1"
               TextTrimming="CharacterEllipsis"/>
  </Border>
  <Button Classes="primary"
          Command="{Binding RunSelectedCommand}"
          Content="Run selected"/>
  <Button Classes="primary"
          Command="{Binding ResumeSelectedCommand}"
          Content="Resume"/>
  <Button x:Name="MarkDoneButton"
          Content="Mark done"
          Command="{Binding MarkSelectedTaskDoneCommand}"
          ToolTip.Tip="Move this task to the archive without running it."
          IsVisible="{Binding IsMarkDoneButtonVisible}"/>
</StackPanel>
