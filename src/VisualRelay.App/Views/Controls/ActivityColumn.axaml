<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:domain="using:VisualRelay.Domain"
             x:Class="VisualRelay.App.Views.Controls.ActivityColumn"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="*,*"
        RowSpacing="10">
    <Border Classes="panel"
            ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                BorderBrush="#252A33"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="RUN LOG"
                       Classes="panelTitle"/>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
              <Button Content="Reveal"
                      Command="{Binding RevealStageArtifactsCommand}"
                      ToolTip.Tip="Reveal selected stage artifacts in file manager"
                      MinHeight="0"
                      FontSize="11"
                      Padding="10,3"/>
              <Border Classes="chip"
                      Padding="8,3">
                <TextBlock Text="{Binding LogScopeLabel}"
                           FontSize="11"
                           Foreground="#8FA6FF"/>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <ListBox Grid.Row="1"
                 Margin="12"
                 ItemsSource="{Binding Events}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type domain:RelayEvent}">
              <Grid RowDefinitions="Auto,Auto"
                    Margin="0,0,0,10">
                <TextBlock Text="{Binding DisplayLine}"
                           ToolTip.Tip="{Binding DisplayLine}"
                           FontFamily="Menlo,Consolas,monospace"
                           FontWeight="SemiBold"
                           Foreground="#53B7F4"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"/>
                <SelectableTextBlock Grid.Row="1"
                                     Text="{Binding DetailLine}"
                                     ToolTip.Tip="{Binding DetailLine}"
                                     Classes="logDetail"
                                     Classes.attention="{Binding IsAttention}"
                                     FontFamily="Menlo,Consolas,monospace"
                                     FontSize="12"
                                     Foreground="#7F8794"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Classes="panel"
            ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                BorderBrush="#252A33"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="LLM COMMANDS"
                       Classes="panelTitle"/>
            <Border Grid.Column="1"
                    Classes="chip"
                    Padding="8,3">
              <TextBlock Text="{Binding TraceEntries.Count}"
                         FontSize="11"
                         Foreground="#C8CED8"/>
            </Border>
          </Grid>
        </Border>

         <ListBox Grid.Row="1"
                   x:Name="TraceList"
                   Margin="12"
                   ItemsSource="{Binding TraceEntries}">
           <ListBox.ItemsPanel>
             <ItemsPanelTemplate>
               <StackPanel/>
             </ItemsPanelTemplate>
           </ListBox.ItemsPanel>
           <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type domain:TraceEntry}">
              <Border Padding="12"
                      Margin="0,0,0,10"
                      Background="#171A20"
                      BorderBrush="#2A303A"
                      BorderThickness="1"
                      CornerRadius="8">
                <Grid RowDefinitions="Auto,Auto">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="8">
                    <Ellipse Width="7"
                             Height="7"
                             Fill="#5AD47D"
                             VerticalAlignment="Center"/>
                    <Grid Grid.Column="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                      <TextBlock Text="{Binding Title}"
                                 FontWeight="SemiBold"
                                 Foreground="#E7ECF3"
                                 MaxLines="1"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding ScopeLabel}"
                                 FontFamily="Menlo,Consolas,monospace"
                                 FontSize="11"
                                 Foreground="#6F7785"
                                 MaxLines="1"/>
                    </Grid>
                  </Grid>
                  <TextBlock Grid.Row="1"
                             Text="{Binding Content}"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="12"
                             LineHeight="17"
                             Foreground="#8E96A3"
                             Margin="15,8,0,0"
                             TextWrapping="Wrap"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</UserControl>
