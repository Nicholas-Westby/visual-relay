<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:controls="using:VisualRelay.App.Views.Controls"
             x:Class="VisualRelay.App.Views.Controls.ActivityColumn"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">
      <!-- Column header -->
      <Border Grid.Row="0"
              BorderBrush="#252A33"
              BorderThickness="0,0,0,1"
              Padding="16,12">
        <Grid ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8">
          <TextBlock Text="ACTIVITY"
                     Classes="panelTitle"/>
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center">
            <Button Content="Reveal"
                    Command="{Binding RevealStageArtifactsCommand}"
                    ToolTip.Tip="Reveal selected stage artifacts in file manager"
                    MinHeight="0"
                    FontSize="11"
                    Padding="10,3"/>
            <Border Classes="chip"
                    Padding="8,3">
              <TextBlock Text="{Binding LogScopeLabel}"
                         FontSize="11"
                         Foreground="#8FA6FF"/>
            </Border>
          </StackPanel>
          <Button Grid.Column="2"
                  Classes="collapseToggle"
                  Command="{Binding ToggleActivityColumnCommand}"
                  ToolTip.Tip="{Binding ActivityColumnHeaderTooltip}"
                  VerticalAlignment="Center">
            <controls:ChevronIcon Direction="{Binding ActivityColumnChevron}"/>
          </Button>
        </Grid>
      </Border>

      <!-- TabControl with 5 tabs -->
      <TabControl Grid.Row="1"
                  SelectedIndex="{Binding ActivityTabIndex}">
        <TabItem Header="Run Log">
          <controls:RunLogView/>
        </TabItem>
        <TabItem Header="Commands">
          <controls:CommandsView/>
        </TabItem>
        <TabItem Header="System"
                 Classes="stageDivider">
          <controls:StageSystemView/>
        </TabItem>
        <TabItem Header="Input">
          <controls:StageInputView/>
        </TabItem>
        <TabItem Header="Output">
          <controls:StageOutputView/>
        </TabItem>
      </TabControl>
    </Grid>
  </Border>
</UserControl>
