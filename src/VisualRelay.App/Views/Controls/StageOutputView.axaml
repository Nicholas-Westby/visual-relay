<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:svc="using:VisualRelay.App.Services"
             xmlns:cvt="using:VisualRelay.App.Views.Controls"
             x:Class="VisualRelay.App.Views.Controls.StageOutputView"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="Auto,Auto,*">
    <!-- Context header -->
    <Border Grid.Row="0"
            BorderBrush="#252A33"
            BorderThickness="0,0,0,1"
            Padding="16,12"
            IsVisible="{Binding StageDetail.Header, Converter={x:Static ObjectConverters.IsNotNull}}">
      <TextBlock Text="{Binding StageDetail.Header}"
                 Classes="panelTitle"/>
    </Border>

    <!-- Raw JSON toggle bar -->
    <Border Grid.Row="1"
            Padding="12,8"
            BorderBrush="#252A33"
            BorderThickness="0,0,0,1"
            IsVisible="{Binding StageDetail.IsOutputReady}">
      <CheckBox Content="Raw JSON"
                IsChecked="{Binding StageDetail.IsOutputRawJson}"
                ToolTip.Tip="{Binding StageDetail.OutputRawToggleTooltip}"
                FontSize="12"
                Foreground="#C8CED8"/>
    </Border>

    <!-- NoStage placeholder -->
    <Border Grid.Row="2"
            IsVisible="{Binding StageDetail.IsOutputNoStage}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="Click a stage to see its system prompt, input prompt, and output."
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- DriverStage message -->
    <Border Grid.Row="2"
            IsVisible="{Binding StageDetail.IsOutputDriverStage}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="This stage runs git directly — no LLM prompt or output."
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- NotComplete transitional -->
    <Border Grid.Row="2"
            IsVisible="{Binding StageDetail.IsOutputNotComplete}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="{Binding StageDetail.Header, StringFormat='Output for {0} will appear once the stage completes.'}"
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- Skipped (stage done but no report — e.g. Fix-verify skipped because Verify passed) -->
    <Border Grid.Row="2"
            IsVisible="{Binding StageDetail.IsOutputSkipped}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="This stage was skipped because Verify passed with no issues."
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- NotAvailable (stage done but output artifact was never committed) -->
    <Border Grid.Row="2"
            IsVisible="{Binding StageDetail.IsOutputNotAvailable}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="{Binding StageDetail.Header, StringFormat='Output for {0} is no longer available after the stage completed.'}"
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- Ready: raw JSON view -->
    <ScrollViewer Grid.Row="2"
                  Padding="16"
                  HorizontalScrollBarVisibility="Disabled"
                  IsVisible="{Binding StageDetail.IsOutputReadyAndRawJson}">
      <SelectableTextBlock Text="{Binding StageDetail.RawJson}"
                            FontFamily="Menlo,Consolas,monospace"
                            FontSize="12"
                            LineHeight="18"
                            Foreground="#C8CED8"
                            TextWrapping="Wrap"/>
    </ScrollViewer>

    <!-- Ready: rendered output fields -->
    <ScrollViewer Grid.Row="2"
                  HorizontalScrollBarVisibility="Disabled"
                  IsVisible="{Binding StageDetail.IsOutputReadyAndNotRawJson}">
      <!-- Inset lives on the content (not ScrollViewer.Padding) so the bottom
           gap is part of the measured extent and the last item stays reachable. -->
      <ItemsControl ItemsSource="{Binding StageDetail.OutputFields}"
                    Margin="8,8,8,16">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type svc:OutputField}">
            <Border Margin="4"
                    HorizontalAlignment="Stretch"
                    BorderBrush="#2A303A"
                    BorderThickness="1"
                    CornerRadius="6">
              <Expander Header="{Binding Label}"
                        IsExpanded="True"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="8,4">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="8">
                  <StackPanel Grid.Row="0"
                              Orientation="Horizontal"
                              Spacing="4">
                    <Button Content="Copy"
                            FontSize="11"
                            Padding="8,3"
                            MinHeight="0"
                            Click="CopyOutputFieldValue_Click"/>
                  </StackPanel>
                  <SelectableTextBlock Grid.Row="1"
                                       Text="{Binding Value}"
                                       FontFamily="Menlo,Consolas,monospace"
                                       FontSize="12"
                                       LineHeight="18"
                                       Foreground="#C8CED8"
                                       TextWrapping="Wrap"/>
                </Grid>
              </Expander>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
