<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:controls="using:VisualRelay.App.Views.Controls"
             x:Class="VisualRelay.App.Views.Controls.QueuePanel"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*,Auto">
      <Grid Row="0"
            RowDefinitions="Auto,Auto"
            RowSpacing="8"
            Margin="16,15,16,12">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto"
              ColumnSpacing="8">
          <TextBlock Grid.Column="0"
                     Text="{Binding TaskListTitle}"
                     Classes="panelTitle"
                     VerticalAlignment="Center"/>
          <Border Grid.Column="1"
                  Classes="chip"
                  Padding="8,3">
            <TextBlock Text="{Binding Tasks.Count}"
                       FontSize="11"
                       Foreground="#C8CED8"/>
          </Border>
          <!-- Grid.Column="2" is the * spacer that absorbs slack -->
          <Button Grid.Column="3"
                  Command="{Binding OpenNewTaskDialogCommand}"
                  Padding="10,4"
                  MinHeight="28"
                  Content="New"/>
          <Button Grid.Column="4"
                  Command="{Binding ToggleArchiveCommand}"
                  Padding="10,4"
                  MinHeight="28"
                  Content="{Binding TaskListToggleText}"/>
          <Button Grid.Column="5"
                  Classes="collapseToggle"
                  Command="{Binding ToggleQueueCommand}"
                  ToolTip.Tip="{Binding QueueHeaderTooltip}"
                  VerticalAlignment="Center">
            <controls:ChevronIcon Direction="{Binding QueueChevron}"/>
          </Button>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Vertical">
          <CheckBox IsChecked="{Binding BypassSandbox}"
                    Content="Bypass nono sandbox"
                    ToolTip.Tip="Runs Swival without the OS sandbox. It will be able to delete files anywhere, not just in the project folder."/>
          <TextBlock Text="⚠ When checked, Swival can delete files anywhere — not just in the project folder."
                     FontSize="11"
                     Foreground="#F0CA66"
                     Margin="20,2,0,0"
                     IsVisible="{Binding BypassSandbox}"/>
        </StackPanel>
      </Grid>

      <ListBox Grid.Row="1"
               x:Name="TaskQueueList"
               Margin="10,0,10,8"
               DragDrop.AllowDrop="True"
               IsVisible="{Binding !NeedsInitialization}"
               ItemsSource="{Binding Tasks}"
               SelectedItem="{Binding SelectedTask}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:TaskRowViewModel}">
            <Border Padding="0"
                    Classes="queueCard"
                    MinHeight="76"
                    Background="{Binding CardBackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    BoxShadow="{Binding CardShadow}">
              <Grid ColumnDefinitions="4,*">
                <Border Classes="selectionRail"
                        Background="{Binding RailBrush}"
                        CornerRadius="8,0,0,8"/>
                <Grid Grid.Column="1"
                      RowDefinitions="Auto,Auto,Auto,Auto,*"
                      Margin="8,12,12,12">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="8">
                    <Ellipse Width="7"
                             Height="7"
                             Fill="{Binding AccentBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Id}"
                               FontWeight="SemiBold"
                               Foreground="#E7ECF3"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
                  <TextBlock Grid.Row="1"
                             Text="{Binding MarkdownPath}"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="11"
                             Foreground="#6F7785"
                             Margin="15,6,0,0"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <Grid Grid.Row="2"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="8"
                        Margin="15,6,0,0">
                    <TextBlock Text="{Binding StateLabel}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{Binding AccentBrush}"
                               MaxLines="1"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ReviewReason}"
                               ToolTip.Tip="{Binding ReviewReason}"
                               FontSize="11"
                               Foreground="#F2C66D"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Text="{Binding MetricsLine}"
                             FontSize="11"
                             Foreground="#8E96A3"
                             Margin="15,5,0,0"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <ProgressBar Grid.Row="4"
                               Height="3"
                               MinHeight="3"
                               Padding="0"
                               Margin="15,10,0,0"
                               VerticalAlignment="Top"
                               Minimum="0"
                               Maximum="1"
                               Value="{Binding ProgressFraction}"
                               Background="#222833"
                               Foreground="{Binding AccentBrush}"
                               CornerRadius="3"/>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Row="1"
              x:Name="InitEmptyState"
              Margin="16"
              Padding="16"
              VerticalAlignment="Top"
              Background="#1B2129"
              BorderBrush="#2C333E"
              BorderThickness="1"
              CornerRadius="8"
              IsVisible="{Binding NeedsInitialization}">
        <StackPanel Spacing="10">
          <TextBlock Text="Initialize this project"
                     FontWeight="SemiBold"
                     Foreground="#E7ECF3"/>
          <TextBlock Text="No .relay/config.json here yet. Set the command Visual Relay should run to test changes, then create the config."
                     TextWrapping="Wrap"
                     FontSize="12"
                     Foreground="#8E96A3"/>
          <TextBox x:Name="InitTestCommandBox"
                   Text="{Binding InitTestCommandInput}"
                   PlaceholderText="e.g. dotnet test"
                   ToolTip.Tip="Examples: dotnet test, pytest, npm test, cargo test, go test ./..."
                   FontFamily="Menlo,Consolas,monospace"/>
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <Button x:Name="CreateConfigButton"
                    Grid.Column="0"
                    Command="{Binding CreateConfigCommand}"
                    Classes="primary"
                    Padding="12,6"
                    HorizontalAlignment="Stretch"
                    Content="Create config"/>
            <Button Grid.Column="1"
                    Command="{Binding FindTestCommandCommand}"
                    Padding="12,6"
                    HorizontalAlignment="Stretch"
                    Content="Find it for me"
                    ToolTip.Tip="Ask the frontier model to infer the test command (requires the model backend)"/>
          </Grid>
          <TextBlock Text="— or starting from an empty folder? —"
                     HorizontalAlignment="Center"
                     FontSize="11"
                     Foreground="#6B7480"/>
          <TextBlock Text="Initialize a git repo and a placeholder test command so the first task can scaffold the project. Visual Relay adopts the real test command once a toolchain appears."
                     TextWrapping="Wrap"
                     FontSize="12"
                     Foreground="#8E96A3"/>
          <Button Command="{Binding BootstrapProjectCommand}"
                  Padding="12,6"
                  HorizontalAlignment="Stretch"
                  Content="Set up empty project"
                  ToolTip.Tip="git init (if needed) + a runnable .relay/config.json + the pre-commit authority hook"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Margin="16"
              Padding="14"
              VerticalAlignment="Top"
              Background="#2A1B1E"
              BorderBrush="#7A2A30"
              BorderThickness="1"
              CornerRadius="8"
              IsVisible="{Binding HasConfigDiagnostic}">
        <StackPanel Spacing="6">
          <TextBlock Text="This project's .relay/config.json could not be read"
                     FontWeight="SemiBold"
                     Foreground="#F0B6BC"/>
          <TextBlock Text="{Binding ConfigDiagnostic}"
                     TextWrapping="Wrap"
                     FontFamily="Menlo,Consolas,monospace"
                     FontSize="12"
                     Foreground="#D9A0A6"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              Background="#1B2028"
              BorderBrush="#252A33"
              BorderThickness="0,1,0,0"
              Padding="14"
              IsVisible="{Binding ShowHfGate}">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding HfGateMessage}"
                     TextWrapping="Wrap"
                     FontWeight="SemiBold"
                     Foreground="#F0CA66"
                     FontSize="12"/>
          <TextBlock Text="{Binding HfPricingNote}"
                     TextWrapping="Wrap"
                     FontSize="11"
                     Foreground="#8E96A3"/>
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <Button Command="{Binding OpenGetKeyUrlCommand}"
                    CommandParameter="https://huggingface.co/settings/tokens"
                    Padding="10,4"
                    MinHeight="28"
                    Content="Get a free token →"/>
            <TextBlock Text="or open Settings ⚙ in the top bar"
                       FontSize="11"
                       Foreground="#8E96A3"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              BorderBrush="#252A33"
              BorderThickness="0,1,0,0"
              Padding="16,12"
              IsVisible="{Binding !ShowHfGate}">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
          <TextBlock Text="{Binding StatusText}"
                     ToolTip.Tip="{Binding StatusText}"
                     Foreground="#8FE3A2"
                     MaxLines="4"
                     TextWrapping="Wrap"
                     VerticalAlignment="Top"/>
          <Button Grid.Column="1"
                  x:Name="StatusExpandButton"
                  Padding="4,2"
                  MinHeight="0"
                  MinWidth="0"
                  FontSize="11"
                  VerticalAlignment="Top"
                  ToolTip.Tip="View full status"
                  IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Button.Flyout>
              <Flyout Placement="TopEdgeAlignedRight">
                <Border Background="#1B2028"
                        BorderBrush="#3A4150"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,12"
                        Width="340"
                        MaxHeight="320">
                  <Grid RowDefinitions="Auto,*" RowSpacing="6"
                        VerticalAlignment="Stretch">
                    <TextBlock Text="STATUS"
                               Foreground="#5A6270"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="280"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                      <SelectableTextBlock Text="{Binding StatusText}"
                                           Foreground="#8FE3A2"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"/>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Flyout>
            </Button.Flyout>
            <TextBlock Text="⤢" Foreground="#5A6270" FontSize="11"/>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
