<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             xmlns:domain="using:VisualRelay.Domain"
             x:Class="VisualRelay.App.Views.Controls.QueuePanel"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*,Auto">
      <Grid Row="0"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="8"
            Margin="16,15,16,12">
        <TextBlock Text="QUEUE"
                   Classes="panelTitle"/>
        <Border Grid.Column="1"
                Classes="chip"
                Padding="8,3">
          <TextBlock Text="{Binding Tasks.Count}"
                     FontSize="11"
                     Foreground="#C8CED8"/>
        </Border>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="6">
          <Button Command="{Binding MoveUpCommand}"
                  Padding="10,4"
                  MinHeight="28"
                  Content="Up"/>
          <Button Command="{Binding MoveDownCommand}"
                  Padding="10,4"
                  MinHeight="28"
                  Content="Down"/>
        </StackPanel>
      </Grid>

      <ListBox Grid.Row="1"
               Margin="10,0,10,8"
               ItemsSource="{Binding Tasks}"
               SelectedItem="{Binding SelectedTask}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type domain:RelayTaskItem}">
            <Border Padding="12"
                    MinHeight="76"
                    Background="#171A20"
                    BorderBrush="#2A303A"
                    BorderThickness="1"
                    CornerRadius="8">
              <Grid RowDefinitions="Auto,Auto,Auto,*">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                  <Ellipse Width="7"
                           Height="7"
                           Fill="#5B7CFA"
                           VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Id}"
                             FontWeight="SemiBold"
                             Foreground="#E7ECF3"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                </Grid>
                <TextBlock Grid.Row="1"
                           Text="{Binding MarkdownPath}"
                           FontFamily="Menlo,Consolas,monospace"
                           FontSize="11"
                           Foreground="#6F7785"
                           Margin="15,6,0,0"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"/>
                <Grid Grid.Row="2"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="8"
                      Margin="15,6,0,0">
                  <TextBlock Text="{Binding StateLabel}"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Foreground="#C8CED8"
                             MaxLines="1"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding ReviewReason}"
                             FontSize="11"
                             Foreground="#F2C66D"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                </Grid>
                <Border Grid.Row="3"
                        Height="3"
                        Margin="15,10,0,0"
                        Background="#222833"
                        CornerRadius="3">
                  <Border Width="92"
                          HorizontalAlignment="Left"
                          Background="#5B7CFA"
                          CornerRadius="3"/>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Row="2"
              BorderBrush="#252A33"
              BorderThickness="0,1,0,0"
              Padding="16,12">
        <TextBlock Text="{Binding StatusText}"
                   Foreground="#8FE3A2"
                   MaxLines="2"
                   TextTrimming="CharacterEllipsis"/>
      </Border>
    </Grid>
  </Border>
</UserControl>
