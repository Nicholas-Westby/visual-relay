<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.QueuePanel"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*,Auto">
      <Grid Row="0"
            RowDefinitions="Auto,Auto"
            RowSpacing="8"
            Margin="16,15,16,12">
        <Grid ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8">
          <TextBlock Text="{Binding TaskListTitle}"
                     Classes="panelTitle"
                     VerticalAlignment="Center"/>
          <Border Grid.Column="1"
                  Classes="chip"
                  Padding="8,3">
            <TextBlock Text="{Binding Tasks.Count}"
                       FontSize="11"
                       Foreground="#C8CED8"/>
          </Border>
          <Button Grid.Column="2"
                  Command="{Binding ToggleArchiveCommand}"
                  Padding="10,4"
                  MinHeight="28"
                  Content="{Binding TaskListToggleText}"/>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="6">
          <Button Command="{Binding MoveUpCommand}"
                  Classes="primary"
                  Padding="10,4"
                  MinHeight="28"
                  Content="Up"/>
          <Button Command="{Binding MoveDownCommand}"
                  Classes="primary"
                  Padding="10,4"
                  MinHeight="28"
                  Content="Down"/>
        </StackPanel>
      </Grid>

      <ListBox Grid.Row="1"
               Margin="10,0,10,8"
               IsVisible="{Binding !NeedsInitialization}"
               ItemsSource="{Binding Tasks}"
               SelectedItem="{Binding SelectedTask}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:TaskRowViewModel}">
            <Border Padding="0"
                    Classes="queueCard"
                    MinHeight="76"
                    Background="{Binding CardBackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    BoxShadow="{Binding CardShadow}">
              <Grid ColumnDefinitions="4,*">
                <Border Classes="selectionRail"
                        Background="{Binding RailBrush}"
                        CornerRadius="8,0,0,8"/>
                <Grid Grid.Column="1"
                      RowDefinitions="Auto,Auto,Auto,Auto,*"
                      Margin="8,12,12,12">
                  <Grid ColumnDefinitions="Auto,*"
                        ColumnSpacing="8">
                    <Ellipse Width="7"
                             Height="7"
                             Fill="{Binding AccentBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Id}"
                               FontWeight="SemiBold"
                               Foreground="#E7ECF3"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
                  <TextBlock Grid.Row="1"
                             Text="{Binding MarkdownPath}"
                             FontFamily="Menlo,Consolas,monospace"
                             FontSize="11"
                             Foreground="#6F7785"
                             Margin="15,6,0,0"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <Grid Grid.Row="2"
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="8"
                        Margin="15,6,0,0">
                    <TextBlock Text="{Binding StateLabel}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{Binding AccentBrush}"
                               MaxLines="1"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ReviewReason}"
                               ToolTip.Tip="{Binding ReviewReason}"
                               FontSize="11"
                               Foreground="#F2C66D"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
                  <TextBlock Grid.Row="3"
                             Text="{Binding MetricsLine}"
                             FontSize="11"
                             Foreground="#8E96A3"
                             Margin="15,5,0,0"
                             MaxLines="1"
                             TextTrimming="CharacterEllipsis"/>
                  <ProgressBar Grid.Row="4"
                               Height="3"
                               MinHeight="3"
                               Padding="0"
                               Margin="15,10,0,0"
                               VerticalAlignment="Top"
                               Minimum="0"
                               Maximum="1"
                               Value="{Binding ProgressFraction}"
                               Background="#222833"
                               Foreground="{Binding AccentBrush}"
                               CornerRadius="3"/>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Row="1"
              Margin="16"
              Padding="16"
              VerticalAlignment="Top"
              Background="#1B2129"
              BorderBrush="#2C333E"
              BorderThickness="1"
              CornerRadius="8"
              IsVisible="{Binding NeedsInitialization}">
        <StackPanel Spacing="10">
          <TextBlock Text="Initialize this project"
                     FontWeight="SemiBold"
                     Foreground="#E7ECF3"/>
          <TextBlock Text="No .relay/config.json here yet. Set the command Visual Relay should run to test changes, then create the config."
                     TextWrapping="Wrap"
                     FontSize="12"
                     Foreground="#8E96A3"/>
          <TextBox Text="{Binding InitTestCommandInput}"
                   PlaceholderText="e.g. dotnet test · pytest · npm test · cargo test · go test ./..."
                   FontFamily="Menlo,Consolas,monospace"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding CreateConfigCommand}"
                    Classes="primary"
                    Padding="12,6"
                    Content="Create config"/>
            <Button Command="{Binding FindTestCommandCommand}"
                    Padding="12,6"
                    Content="Find it for me"
                    ToolTip.Tip="Ask the frontier model to infer the test command (requires the model backend)"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Margin="16"
              Padding="14"
              VerticalAlignment="Top"
              Background="#2A1B1E"
              BorderBrush="#7A2A30"
              BorderThickness="1"
              CornerRadius="8"
              IsVisible="{Binding HasConfigDiagnostic}">
        <StackPanel Spacing="6">
          <TextBlock Text="This project's .relay/config.json could not be read"
                     FontWeight="SemiBold"
                     Foreground="#F0B6BC"/>
          <TextBlock Text="{Binding ConfigDiagnostic}"
                     TextWrapping="Wrap"
                     FontFamily="Menlo,Consolas,monospace"
                     FontSize="12"
                     Foreground="#D9A0A6"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              BorderBrush="#252A33"
              BorderThickness="0,1,0,0"
              Padding="16,12">
        <TextBlock Text="{Binding StatusText}"
                   Foreground="#8FE3A2"
                   MaxLines="2"
                   TextTrimming="CharacterEllipsis"/>
      </Border>
    </Grid>
  </Border>
</UserControl>
