<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.StageBoard"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="panel"
          ClipToBounds="True">
    <Grid RowDefinitions="Auto,*">
      <Border Grid.Row="0"
              BorderBrush="#252A33"
              BorderThickness="0,0,0,1"
              Padding="16,12">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="STAGES"
                     Classes="panelTitle"
                     VerticalAlignment="Center"/>
          <Border Grid.Column="1"
                  Classes="chip"
                  Padding="8,3">
            <TextBlock Text="{Binding Stages.Count}"
                       FontSize="11"
                       Foreground="#C8CED8"/>
          </Border>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1"
                    Margin="14"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Stages}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:StageRowViewModel}">
              <Button Classes="stageButton"
                      Width="165"
                      Command="{Binding $parent[ItemsControl].DataContext.SelectStageCommand}"
                      CommandParameter="{Binding}">
                <Border Padding="12"
                        MinHeight="64"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="{Binding CardBorderThickness}"
                        CornerRadius="8"
                        BoxShadow="{Binding CardShadow}"
                        Background="{Binding CardBackgroundBrush}">
                  <Grid RowDefinitions="Auto,Auto,Auto">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="6">
                      <TextBlock Text="{Binding Ordinal}"
                                 FontFamily="Menlo,Consolas,monospace"
                                 FontSize="11"
                                 FontWeight="Bold"
                                 Foreground="{Binding AccentBrush}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Name}"
                                 FontWeight="SemiBold"
                                 Foreground="#E7ECF3"
                                 MaxLines="1"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding StatusLabel}"
                               FontSize="11"
                               Foreground="{Binding AccentBrush}"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2"
                               Text="{Binding MetricLabel}"
                               FontSize="11"
                               Foreground="#8E96A3"
                               MaxLines="1"
                               TextTrimming="CharacterEllipsis"/>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
