<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisualRelay.App.ViewModels"
             x:Class="VisualRelay.App.Views.Controls.StageSystemView"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="Auto,*">
    <!-- Context header -->
    <Border Grid.Row="0"
            BorderBrush="#252A33"
            BorderThickness="0,0,0,1"
            Padding="16,12"
            IsVisible="{Binding StageDetail.Header, Converter={x:Static ObjectConverters.IsNotNull}}">
      <TextBlock Text="{Binding StageDetail.Header}"
                 Classes="panelTitle"/>
    </Border>

    <!-- NoStage placeholder -->
    <Border Grid.Row="1"
            IsVisible="{Binding StageDetail.IsSystemNoStage}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="Click a stage to see its system prompt, input prompt, and output."
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- DriverStage message -->
    <Border Grid.Row="1"
            IsVisible="{Binding StageDetail.IsSystemDriverStage}"
            Padding="24"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <TextBlock Text="This stage runs git directly — no LLM prompt or output."
                 FontSize="13"
                 Foreground="#6F7785"
                 TextWrapping="Wrap"
                 TextAlignment="Center"/>
    </Border>

    <!-- Ready: system prompt in ScrollViewer+SelectableTextBlock -->
    <ScrollViewer Grid.Row="1"
                  Padding="16"
                  HorizontalScrollBarVisibility="Disabled"
                  IsVisible="{Binding StageDetail.IsSystemReady}">
      <SelectableTextBlock Text="{Binding StageDetail.SystemPromptText}"
                           FontFamily="Menlo,Consolas,monospace"
                           FontSize="13"
                           LineHeight="21"
                           Foreground="#DCE2EA"
                           TextWrapping="Wrap"/>
    </ScrollViewer>
  </Grid>
</UserControl>
