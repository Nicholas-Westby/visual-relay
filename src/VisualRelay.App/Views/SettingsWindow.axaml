<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisualRelay.App.ViewModels"
        xmlns:controls="using:VisualRelay.App.Views.Controls"
        xmlns:buttons="using:VisualRelay.App.Views.Controls.Buttons"
        x:Class="VisualRelay.App.Views.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Settings"
        Width="520"
        Height="1270"
        MinWidth="420"
        MinHeight="320"
        CanResize="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#1A1E26">
  <!-- Single scroll region for short screens; at the default size the whole
       panel fits so no scrollbar is shown. The settings content lives in the
       reusable SettingsPanel control (its own code-behind + bindings intact). -->
  <Grid RowDefinitions="*,Auto">
    <controls:SettingsPanel Grid.Row="0"/>
    <Border Grid.Row="1"
            Background="#12151C"
            BorderBrush="#252A33"
            BorderThickness="0,1,0,0"
            Padding="16,10">
      <buttons:CommonButton Content="Close"
                            HorizontalAlignment="Right"
                            Click="OnCloseClick"/>
    </Border>
  </Grid>
</Window>
