<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VisualRelay.App.App"
             xmlns:local="using:VisualRelay.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://VisualRelay.App/Styles/VisualRelayTheme.axaml"/>
    </Application.Styles>
</Application>
