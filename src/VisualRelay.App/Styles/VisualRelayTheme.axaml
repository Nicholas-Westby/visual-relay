<Styles xmlns="https://github.com/avaloniaui"
        xmlns:controls="using:VisualRelay.App.Views.Controls">
  <Style Selector="Button">
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Background" Value="#1A1E25"/>
    <Setter Property="BorderBrush" Value="#2B313C"/>
    <Setter Property="Foreground" Value="#DDE3EC"/>
  </Style>
  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#222833"/>
    <Setter Property="BorderBrush" Value="#394252"/>
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#5B7CFA"/>
    <Setter Property="BorderBrush" Value="#6B8BFF"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Button.warning">
    <Setter Property="Background" Value="#2B2416"/>
    <Setter Property="BorderBrush" Value="#9E7A2D"/>
    <Setter Property="Foreground" Value="#F0CA66"/>
  </Style>
  <Style Selector="Button.stageButton">
    <Setter Property="Margin" Value="4"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
  </Style>
  <Style Selector="Button.stageButton:pointerover">
    <Setter Property="Background" Value="Transparent"/>
  </Style>
  <Style Selector="Button.path">
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Background" Value="#15181F"/>
    <Setter Property="BorderBrush" Value="#2A303A"/>
    <Setter Property="Padding" Value="14,9"/>
  </Style>
  <Style Selector="Button.hyperlink">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Foreground" Value="#5575F2"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Padding" Value="4,2"/>
  </Style>
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0,0,0,8"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="MinHeight" Value="0"/>
  </Style>
  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="Transparent"/>
  </Style>
  <!-- Drag-reorder insertion affordance: an accent line above/below the row the
       dragged card would land next to. Toggled from QueuePanel code-behind. -->
  <Style Selector="ListBoxItem.drop-above">
    <Setter Property="BorderBrush" Value="#3191FF"/>
    <Setter Property="BorderThickness" Value="0,2,0,0"/>
  </Style>
  <Style Selector="ListBoxItem.drop-below">
    <Setter Property="BorderBrush" Value="#3191FF"/>
    <Setter Property="BorderThickness" Value="0,0,0,2"/>
  </Style>
  <Style Selector="Border.queueCard">
    <Setter Property="Background" Value="#171A20"/>
    <Setter Property="BorderBrush" Value="#2A303A"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
  </Style>
  <Style Selector="ListBoxItem:pointerover Border.queueCard">
    <Setter Property="Background" Value="#1A1F29"/>
    <Setter Property="BorderBrush" Value="#3B4658"/>
  </Style>
  <Style Selector="ListBoxItem:selected Border.queueCard">
    <Setter Property="Background" Value="#16233D"/>
    <Setter Property="BorderBrush" Value="#3191FF"/>
    <Setter Property="BorderThickness" Value="2"/>
    <Setter Property="BoxShadow" Value="0 0 22 0 #553F8CFF"/>
  </Style>
  <Style Selector="ListBoxItem:selected Border.selectionRail">
    <Setter Property="Background" Value="#3191FF"/>
  </Style>
  <Style Selector="ListBoxItem:pointerover Border.selectionRail">
    <Setter Property="Background" Value="#3191FF"/>
  </Style>
  <Style Selector="TextBlock.panelTitle">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="#9AA3B1"/>
  </Style>
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="#12151B"/>
    <Setter Property="BorderBrush" Value="#252A33"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BoxShadow" Value="0 18 40 0 #3A000000"/>
  </Style>
  <Style Selector="Border.chip">
    <Setter Property="Background" Value="#1A202A"/>
    <Setter Property="BorderBrush" Value="#2A3340"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="11"/>
    <Setter Property="Padding" Value="9,4"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>
  <Style Selector="Border.chip > TextBlock">
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>
  <!-- Panel collapse rails and toggles. -->
  <Style Selector="Border.rail">
    <Setter Property="Background" Value="#12151B"/>
    <Setter Property="BorderBrush" Value="#252A33"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BoxShadow" Value="0 18 40 0 #3A000000"/>
    <Setter Property="Padding" Value="6"/>
  </Style>
  <Style Selector="TextBlock.railTitle">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="#6F7785"/>
  </Style>
  <!-- Panel collapse toggle — unified affordance for header and rail. -->
  <Style Selector="Button.collapseToggle">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width" Value="26"/>
    <Setter Property="Height" Value="26"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="Foreground" Value="#6F7785"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.collapseToggle:pointerover">
    <Setter Property="Foreground" Value="#DDE3EC"/>
  </Style>
  <!-- The vector chevron tracks its toggle's foreground via style, so it
       lightens on :pointerover without any per-instance binding hop. -->
  <Style Selector="Button.collapseToggle controls|ChevronIcon">
    <Setter Property="Foreground" Value="#6F7785"/>
  </Style>
  <Style Selector="Button.collapseToggle:pointerover controls|ChevronIcon">
    <Setter Property="Foreground" Value="#DDE3EC"/>
  </Style>
  <!-- Master Focus/Restore toggle — the primary "collapse everything"
       affordance: a larger hit area, stronger contrast and a subtle border so
       it reads as distinctly heavier than the faint per-panel chevrons. -->
  <Style Selector="Button.focusToggle">
    <Setter Property="Background" Value="#1E2533"/>
    <Setter Property="BorderBrush" Value="#3B4658"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Width" Value="34"/>
    <Setter Property="Height" Value="30"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="MinHeight" Value="0"/>
    <Setter Property="Foreground" Value="#C7D4FF"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.focusToggle:pointerover">
    <Setter Property="Background" Value="#283246"/>
    <Setter Property="BorderBrush" Value="#5B7CFA"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Button.focusToggle controls|FocusToggleIcon">
    <Setter Property="Foreground" Value="#C7D4FF"/>
  </Style>
  <Style Selector="Button.focusToggle:pointerover controls|FocusToggleIcon">
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <!-- Run-log detail line: compact by default, wraps when the event needs attention. -->
  <Style Selector="SelectableTextBlock.logDetail">
    <Setter Property="MaxLines" Value="1"/>
    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
  </Style>
  <Style Selector="SelectableTextBlock.logDetail.attention">
    <Setter Property="MaxLines" Value="0"/>
    <Setter Property="TextTrimming" Value="None"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>
  <Style Selector="TabItem.stageDivider">
    <Setter Property="BorderBrush" Value="#3A404A"/>
    <Setter Property="BorderThickness" Value="1,0,0,0"/>
  </Style>
</Styles>
