<Styles xmlns="https://github.com/avaloniaui">
  <Style Selector="Button">
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Background" Value="#1A1E25"/>
    <Setter Property="BorderBrush" Value="#2B313C"/>
    <Setter Property="Foreground" Value="#DDE3EC"/>
  </Style>
  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#222833"/>
    <Setter Property="BorderBrush" Value="#394252"/>
  </Style>
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="#5B7CFA"/>
    <Setter Property="BorderBrush" Value="#6B8BFF"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
  </Style>
  <Style Selector="Button.warning">
    <Setter Property="Background" Value="#2B2416"/>
    <Setter Property="BorderBrush" Value="#9E7A2D"/>
    <Setter Property="Foreground" Value="#F0CA66"/>
  </Style>
  <Style Selector="Button.path">
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Background" Value="#15181F"/>
    <Setter Property="BorderBrush" Value="#2A303A"/>
    <Setter Property="Padding" Value="14,9"/>
  </Style>
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Margin" Value="0,0,0,8"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="MinHeight" Value="0"/>
  </Style>
  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="#18223B"/>
  </Style>
  <Style Selector="TextBlock.panelTitle">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="#9AA3B1"/>
  </Style>
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="#12151B"/>
    <Setter Property="BorderBrush" Value="#252A33"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="BoxShadow" Value="0 18 40 0 #3A000000"/>
  </Style>
  <Style Selector="Border.chip">
    <Setter Property="Background" Value="#1B2130"/>
    <Setter Property="BorderBrush" Value="#303A4C"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="9,4"/>
  </Style>
</Styles>
