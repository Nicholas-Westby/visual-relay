# Normalize line endings. The repo is developed primarily on macOS/Linux, so the
# default for every text file is LF in both the repo and the working tree — this
# also overrides a Windows clone's core.autocrlf=true so C#/AXAML/bash stay LF.
* text=auto eol=lf

# The Windows launchers must be CRLF in the working tree: cmd.exe and PowerShell
# are happiest with CRLF, mirroring the gradlew.bat / mvnw.cmd convention.
*.cmd text eol=crlf
*.ps1 text eol=crlf

# The bash launcher and shell scripts/hooks stay LF on every platform.
visual-relay text eol=lf
*.sh text eol=lf
.githooks/* text eol=lf
